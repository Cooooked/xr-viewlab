<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="XRViewLab.UI.FailureDiagnosticsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="ViewLab — What happened?" Width="620" Height="480" WindowStartupLocation="CenterOwner" Background="#0A0B0C" Foreground="#E8E8E8" FontFamily="Segoe UI" FontSize="13">
  <Window.Resources>
    <SolidColorBrush x:Key="MutedBrush" Color="#9A9A9A" />
    <SolidColorBrush x:Key="BorderBrush" Color="#2B2D31" />
    <SolidColorBrush x:Key="ConfirmedBrush" Color="#E0645A" />
    <SolidColorBrush x:Key="LikelyBrush" Color="#D8A94A" />
    <Style x:Key="{x:Type Button}" TargetType="{x:Type Button}">
      <Setter Property="Background" Value="#1A2637" />
      <Setter Property="Foreground" Value="#E8E8E8" />
      <Setter Property="BorderBrush" Value="#29364A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,2" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Findings from the current ViewLab.log and the last settings-window crash, if any. &quot;Confirmed&quot; quotes exact logged evidence; &quot;Likely&quot; is a plausible explanation stated as a hypothesis, not a fact." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,0,8" />

    <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl Name="FindingsList" Margin="10">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,8" Margin="0,0,0,4">
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <Border Background="{Binding CertaintyBrush}" CornerRadius="3" Padding="6,1" Margin="0,0,8,0">
                      <TextBlock Text="{Binding CertaintyLabel}" FontSize="10" FontWeight="SemiBold" Foreground="#0A0B0C" />
                    </Border>
                    <TextBlock Text="{Binding Category}" FontWeight="SemiBold" Foreground="#E8E8E8" FontSize="13" />
                  </StackPanel>
                  <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Foreground="#C8C8C8" FontSize="12" Margin="0,4,0,4" />
                  <TextBlock Text="{Binding EvidenceLabeled}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="10" FontFamily="Consolas" Margin="0,0,0,4" />
                  <TextBlock Text="{Binding RecommendationLabeled}" TextWrapping="Wrap" Foreground="#8FB0D8" FontSize="11" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Refresh" Click="Refresh_Click" Margin="0,0,8,0" />
      <Button Content="Close" Click="Close_Click" />
    </StackPanel>
  </Grid>
</Window>
