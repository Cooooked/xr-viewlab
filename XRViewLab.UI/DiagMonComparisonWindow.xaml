<Window x:Class="XRViewLab.UI.DiagMonComparisonWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ViewLab — Session comparison" Width="1050" Height="560" MinWidth="760" MinHeight="420" Background="#101112" Foreground="#E4E4E4" WindowStartupLocation="CenterOwner">
  <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="DiagMonDarkStyles.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
  <Grid Margin="14">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <TextBlock Text="Selected session comparison" FontSize="18" FontWeight="SemiBold"/>
    <DataGrid Grid.Row="2" x:Name="ComparisonGrid" AutoGenerateColumns="False" IsReadOnly="True" Background="#111215" Foreground="#E4E4E4" BorderBrush="#34363B">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="145"/>
        <DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="*"/>
        <DataGridTextColumn Header="Average FPS" Binding="{Binding AverageFps}" Width="90"/>
        <DataGridTextColumn Header="P99 frame interval (ms)" Binding="{Binding P99Ms}" Width="135"/>
        <DataGridTextColumn Header="Severe stutters" Binding="{Binding SevereStutters}" Width="100"/>
        <DataGridTextColumn Header="Peak GPU (%)" Binding="{Binding PeakGpu}" Width="90"/>
        <DataGridTextColumn Header="Peak VRAM (MB)" Binding="{Binding PeakVram}" Width="100"/>
        <DataGridTextColumn Header="Memory change (MB)" Binding="{Binding MemoryGrowth}" Width="120"/>
        <DataGridTextColumn Header="Δ FPS vs first" Binding="{Binding FpsDelta}" Width="95"/>
        <DataGridTextColumn Header="Δ P99 vs first" Binding="{Binding P99Delta}" Width="95"/>
      </DataGrid.Columns>
    </DataGrid>
    <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="#9DA5B1" Text="The first selected session is the reference. Missing evidence is shown as unavailable; ViewLab does not invent it."/>
  </Grid>
</Window>
