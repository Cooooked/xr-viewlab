<Window x:Class="XRViewLab.UI.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="XR ViewLab App Profile"
        Width="460"
        Height="360"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Foreground="#E8E8E8"
        FontFamily="Segoe UI"
        FontSize="14">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101112"/>
        <SolidColorBrush x:Key="RedBrush" Color="#C90012"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2B2D31"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9A9A9A"/>
        <SolidColorBrush x:Key="InputBrush" Color="#080909"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#3A3D42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="CaretBrush" Value="#E8E8E8"/>
            <Setter Property="MinWidth" Value="96"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1A2637"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#29364A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource RedBrush}"/>
            <Setter Property="BorderBrush" Value="#EC3038"/>
        </Style>
    </Window.Resources>

    <Border Background="#171819" BorderBrush="#303236" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="#101112" CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="APP PROFILE" Margin="18,0,0,0" VerticalAlignment="Center" Foreground="#9A9A9A" FontWeight="SemiBold"/>
                    <Button Content="X" Width="46" Padding="0" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Click="Cancel_Click"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="16" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="AppNameText" Grid.ColumnSpan="3" FontSize="16" FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="2" Text="Top" VerticalAlignment="Center"/>
                    <TextBox x:Name="TopBox" Grid.Row="2" Grid.Column="1" TextChanged="Values_Changed"/>
                    <TextBlock x:Name="TopHint" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>

                    <TextBlock Grid.Row="4" Text="Bottom" VerticalAlignment="Center"/>
                    <TextBox x:Name="BottomBox" Grid.Row="4" Grid.Column="1" TextChanged="Values_Changed"/>
                    <TextBlock x:Name="BottomHint" Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>

                    <TextBlock x:Name="CombinedHint" Grid.Row="6" Grid.ColumnSpan="3" Foreground="{StaticResource MutedBrush}"/>

                    <StackPanel Grid.Row="8" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <Button Content="Save" Style="{StaticResource RedButton}" MinWidth="86" Click="Save_Click"/>
                        <Button Content="Use global" MinWidth="104" Margin="10,0,0,0" Click="UseGlobal_Click"/>
                        <Button Content="Cancel" MinWidth="86" Margin="10,0,0,0" Click="Cancel_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
