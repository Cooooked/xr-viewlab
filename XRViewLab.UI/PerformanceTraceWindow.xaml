<Window x:Class="XRViewLab.UI.PerformanceTraceWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ViewLab — Last Performance Trace" Width="1120" Height="700" MinWidth="760" MinHeight="480" Background="#101114" Foreground="#E8E8E8">
  <Grid Margin="14">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <DockPanel Margin="0,0,0,8">
      <TextBlock Name="SummaryText" VerticalAlignment="Center" Foreground="#B8B8B8"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Zoom in" Padding="9,4" Margin="3,0" Click="ZoomIn_Click"/>
        <Button Content="Zoom out" Padding="9,4" Margin="3,0" Click="ZoomOut_Click"/>
        <Button Content="Reset view" Padding="9,4" Margin="3,0" Click="ResetView_Click"/>
        <Button Content="Previous marker" Padding="9,4" Margin="3,0" Click="PreviousMarker_Click"/>
        <Button Content="Next marker" Padding="9,4" Margin="3,0" Click="NextMarker_Click"/>
      </StackPanel>
    </DockPanel>
    <TextBlock Grid.Row="1" Name="StatsText" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#D7DCE3"/>
    <WrapPanel Grid.Row="2" Margin="0,0,0,8">
      <TextBlock Text="Series: " VerticalAlignment="Center" Foreground="#AEB5C0"/>
      <CheckBox Name="ActualSeries" Content="Actual interval" Foreground="#32D2FF" IsChecked="True" Margin="5,0" Checked="SeriesChanged" Unchecked="SeriesChanged"/>
      <CheckBox Name="TargetSeries" Content="Detected cadence" Foreground="#F4C95D" IsChecked="True" Margin="5,0" Checked="SeriesChanged" Unchecked="SeriesChanged"/>
      <CheckBox Name="DisplaySeries" Content="Display period" Foreground="#9B8CFF" IsChecked="True" Margin="5,0" Checked="SeriesChanged" Unchecked="SeriesChanged"/>
      <CheckBox Name="AppSeries" Content="App work" Foreground="#7CE38B" Margin="5,0" Checked="SeriesChanged" Unchecked="SeriesChanged"/>
      <CheckBox Name="WaitSeries" Content="Runtime wait" Foreground="#FF9E64" Margin="5,0" Checked="SeriesChanged" Unchecked="SeriesChanged"/>
      <CheckBox Name="SubmitSeries" Content="Submit" Foreground="#E879F9" Margin="5,0" Checked="SeriesChanged" Unchecked="SeriesChanged"/>
      <CheckBox Name="BudgetGuides" Content="Frame-budget guides" IsChecked="True" Margin="14,0,5,0" Checked="SeriesChanged" Unchecked="SeriesChanged"/>
    </WrapPanel>
    <Border Grid.Row="3" Background="#171A1F" BorderBrush="#323740" BorderThickness="1" CornerRadius="3">
      <!-- Background MUST be non-null (Transparent) or the Canvas gets no mouse events over empty
           areas, so wheel-zoom / drag-pan / hover only fire when exactly over a plotted line. -->
      <Canvas Name="GraphCanvas" Background="Transparent" ClipToBounds="True" SizeChanged="GraphCanvas_SizeChanged" MouseWheel="GraphCanvas_MouseWheel"
              MouseLeftButtonDown="GraphCanvas_MouseLeftButtonDown" MouseLeftButtonUp="GraphCanvas_MouseLeftButtonUp"
              MouseRightButtonDown="GraphCanvas_MouseRightButtonDown"
              MouseMove="GraphCanvas_MouseMove" MouseLeave="GraphCanvas_MouseLeave" Cursor="Cross"/>
    </Border>
    <Grid Grid.Row="4" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <TextBlock Name="HoverText" Foreground="#D7DCE3" Text="Wheel = zoom time · Ctrl+wheel = vertical scale · drag = pan · right-click = reset · hover for values"/>
      <TextBlock Grid.Column="1" Name="MarkerText" Foreground="#35EAD7"/>
    </Grid>
  </Grid>
</Window>
