<Window x:Class="XRViewLab.UI.PerformanceTraceWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ViewLab — Last Performance Trace" Width="960" Height="560" MinWidth="620" MinHeight="360" Background="#101114" Foreground="#E8E8E8">
  <Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <DockPanel Margin="0,0,0,10">
      <TextBlock Name="SummaryText" VerticalAlignment="Center" Foreground="#B8B8B8"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Previous marker" Padding="9,4" Margin="4,0" Click="PreviousMarker_Click"/>
        <Button Content="Next marker" Padding="9,4" Margin="4,0" Click="NextMarker_Click"/>
      </StackPanel>
    </DockPanel>
    <Border Grid.Row="1" Background="#171A1F" BorderBrush="#323740" BorderThickness="1" CornerRadius="3" Padding="8">
      <Canvas Name="GraphCanvas" ClipToBounds="True" SizeChanged="GraphCanvas_SizeChanged"/>
    </Border>
    <TextBlock Grid.Row="2" Name="MarkerText" Margin="0,9,0,0" Foreground="#35EAD7" Text="Numbered cyan lines are exact bind timestamps in the native trace."/>
  </Grid>
</Window>
