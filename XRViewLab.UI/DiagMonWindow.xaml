<Window x:Class="XRViewLab.UI.DiagMonWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ViewLab — DiagMon(ster)" Width="980" Height="720" MinWidth="760" MinHeight="560" Background="#101112" Foreground="#E4E4E4" WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries><ResourceDictionary Source="DiagMonDarkStyles.xaml"/></ResourceDictionary.MergedDictionaries>
      <SolidColorBrush x:Key="Panel" Color="#191A1D"/><SolidColorBrush x:Key="Border" Color="#34363B"/><SolidColorBrush x:Key="Muted" Color="#96989F"/>
    </ResourceDictionary>
  </Window.Resources>
  <Grid Margin="14">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="10"/><RowDefinition Height="Auto"/><RowDefinition Height="10"/><RowDefinition Height="*"/></Grid.RowDefinitions>
    <Grid>
      <TextBlock Text="DiagMon(ster)" FontSize="22" FontWeight="SemiBold"/>
      <Border Width="28" Height="28" CornerRadius="14" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand" ToolTip="DiagMon(ster) guide" Background="Transparent" BorderBrush="White" BorderThickness="1.5" MouseLeftButtonUp="Help_Click">
        <TextBlock Text="?" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
    </Grid>
    <Border Grid.Row="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="5" Padding="12">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="190"/><ColumnDefinition Width="14"/><ColumnDefinition Width="130"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="Auto"/><RowDefinition Height="10"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="Capture mode" VerticalAlignment="Center"/><ComboBox x:Name="ModeCombo" Grid.Column="1" SelectionChanged="ModeCombo_SelectionChanged"/>
        <TextBlock Grid.Column="3" Text="Target selection" VerticalAlignment="Center"/><ComboBox x:Name="TargetModeCombo" Grid.Column="4" SelectionChanged="TargetModeCombo_SelectionChanged"/>
        <TextBlock Grid.Row="2" Text="Target process" VerticalAlignment="Center"/><ComboBox x:Name="ProcessCombo" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" DisplayMemberPath="Display"/>
        <TextBlock Grid.Row="4" Text="User label" VerticalAlignment="Center"/><TextBox x:Name="LabelBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" ToolTip="A short workload label, such as training-lap or editor-export."/>
        <WrapPanel Grid.Row="6" Grid.ColumnSpan="5">
          <Button x:Name="StartButton" Content="Start Capture" Click="Start_Click" Background="#7B1020"/><Button x:Name="StopButton" Content="Stop Capture" Click="Stop_Click" IsEnabled="False"/>
          <Button x:Name="OpenCurrentButton" Content="Open Current Session" Click="OpenCurrent_Click" IsEnabled="False"/><Button Content="Open Session Library" Click="OpenLibrary_Click"/>
          <Button Content="Open VR Session Graph" Click="OpenVrSessionGraph_Click" ToolTip="Open the latest durable ViewLab VR performance trace."/>
          <Button x:Name="ExportButton" Content="Export Analysis Package" Click="Export_Click" IsEnabled="False"/>
        </WrapPanel>
      </Grid>
    </Border>
    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions><ColumnDefinition Width="310"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="5" Padding="12">
        <StackPanel>
          <TextBlock Text="CURRENT CAPTURE" Foreground="{StaticResource Muted}" FontWeight="SemiBold"/><TextBlock x:Name="StatusText" Text="Idle" FontSize="18" Margin="0,7,0,0"/><TextBlock x:Name="ElapsedText" Text="00:00:00" FontSize="28" Margin="0,4"/><TextBlock x:Name="TargetText" Text="No target selected" TextWrapping="Wrap"/><TextBlock x:Name="ModeHelpText" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,0"/><TextBlock x:Name="RetentionText" Foreground="#D4A85B" TextWrapping="Wrap" Margin="0,10,0,0"/><TextBlock x:Name="RecordingOptInText" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,0" Visibility="Collapsed"/>
          <Expander Header="History retention guidance" Margin="0,10,0,0" Foreground="#B8B8B8">
            <StackPanel Margin="6,5,0,0">
              <TextBlock Text="Days / session count / maximum MB" Foreground="{StaticResource Muted}" FontSize="10"/>
              <WrapPanel Margin="0,3,0,5"><TextBox x:Name="RetentionDaysBox" Width="55" Margin="0,0,5,0"/><TextBox x:Name="RetentionCountBox" Width="55" Margin="0,0,5,0"/><TextBox x:Name="RetentionMbBox" Width="65"/></WrapPanel>
              <Button Content="Save guidance" Click="SaveRetention_Click" HorizontalAlignment="Left"/>
              <TextBlock Text="ViewLab warns at these limits and never deletes evidence automatically. Delete selected sessions from the library." TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="9" Margin="0,4,0,0"/>
            </StackPanel>
          </Expander>
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Background="{StaticResource Panel}" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="5" Padding="12">
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="COLLECTORS" Foreground="{StaticResource Muted}" FontWeight="SemiBold"/><DataGrid x:Name="CollectorGrid" Grid.Row="2"><DataGrid.Columns><DataGridTextColumn Header="Collector" Binding="{Binding Name}" Width="150"/><DataGridTextColumn Header="State" Binding="{Binding State}" Width="85"/><DataGridTextColumn Header="Detail" Binding="{Binding Message}" Width="*"/></DataGrid.Columns></DataGrid></Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
