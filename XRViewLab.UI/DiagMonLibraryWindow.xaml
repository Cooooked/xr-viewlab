<Window x:Class="XRViewLab.UI.DiagMonLibraryWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="ViewLab — DiagMon(ster) Session Library" Width="1250" Height="720" MinWidth="900" Background="#101112" Foreground="#E4E4E4" WindowStartupLocation="CenterOwner">
  <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceDictionary Source="DiagMonDarkStyles.xaml"/></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
  <Grid Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/><RowDefinition Height="10"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="190"/><ColumnDefinition Width="15"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Filter" VerticalAlignment="Center" Margin="0,0,6,0"/><TextBox x:Name="FilterBox" Grid.Column="1" TextChanged="Filter_Changed" Background="#191A1D" Foreground="#E4E4E4" BorderBrush="#41434A" Padding="5"/><TextBlock Grid.Column="3" Text="Validation" VerticalAlignment="Center" Margin="0,0,6,0"/><ComboBox x:Name="ValidationFilter" Grid.Column="4" SelectionChanged="Filter_Changed" Background="#24262B" Foreground="#E4E4E4"/></Grid>
    <DataGrid x:Name="SessionsGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow" SelectionChanged="SessionsGrid_SelectionChanged" Background="#111215" Foreground="#E4E4E4" BorderBrush="#34363B" CanUserSortColumns="True" HeadersVisibility="Column">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Date" Binding="{Binding DateDisplay}" Width="145"/><DataGridTextColumn Header="Application" Binding="{Binding Application}" Width="120"/><DataGridTextColumn Header="Duration" Binding="{Binding DurationDisplay}" Width="75"/><DataGridTextColumn Header="Label" Binding="{Binding UserLabel}" Width="120"/><DataGridTextColumn Header="Mode" Binding="{Binding CaptureMode}" Width="75"/><DataGridTextColumn Header="Avg FPS" Binding="{Binding AverageFps, StringFormat=0.0}" Width="70"/><DataGridTextColumn Header="P99 ms" Binding="{Binding P99Ms, StringFormat=0.00}" Width="70"/><DataGridTextColumn Header="Stutters" Binding="{Binding SevereStutters}" Width="65"/><DataGridTextColumn Header="Peak GPU" Binding="{Binding PeakGpuPct, StringFormat=0.0}" Width="70"/><DataGridTextColumn Header="GPU MB" Binding="{Binding PeakGpuMemoryMb, StringFormat=0}" Width="65"/><DataGridTextColumn Header="Mem Δ MB" Binding="{Binding MemoryGrowthMb, StringFormat=0.0}" Width="75"/><DataGridTextColumn Header="Validation" Binding="{Binding Validation}" Width="85"/><DataGridTextColumn Header="Type" Binding="{Binding SessionType}" Width="85"/><DataGridTextColumn Header="Comparable" Binding="{Binding Comparability}" Width="85"/><DataGridTextColumn Header="Tags" Binding="{Binding Tags}" Width="*"/>
      </DataGrid.Columns>
    </DataGrid>
    <Border Grid.Row="4" Background="#191A1D" BorderBrush="#34363B" BorderThickness="1" CornerRadius="4" Padding="10"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="7"/><RowDefinition Height="Auto"/><RowDefinition Height="7"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="170"/><ColumnDefinition Width="15"/><ColumnDefinition Width="85"/><ColumnDefinition Width="180"/><ColumnDefinition Width="15"/><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <TextBlock Text="Validation" VerticalAlignment="Center"/><ComboBox x:Name="ValidationCombo" Grid.Column="1"/><TextBlock Grid.Column="3" Text="Session type" VerticalAlignment="Center"/><ComboBox x:Name="TypeCombo" Grid.Column="4"/><TextBlock Grid.Column="6" Text="Tags" VerticalAlignment="Center"/><TextBox x:Name="TagsBox" Grid.Column="7" Background="#111215" Foreground="#E4E4E4" BorderBrush="#41434A" Padding="4" ToolTip="Comma-separated tags"/>
      <TextBlock Grid.Row="2" Text="Notes" VerticalAlignment="Top"/><TextBox x:Name="NotesBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="7" Height="55" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#111215" Foreground="#E4E4E4" BorderBrush="#41434A" Padding="4"/>
      <WrapPanel Grid.Row="4" Grid.ColumnSpan="8"><Button Content="Save metadata" Click="Save_Click" Padding="9,4" Margin="0,0,7,0"/><Button Content="Open session" Click="Open_Click" Padding="9,4" Margin="0,0,7,0"/><Button Content="Compare selected" Click="Compare_Click" Padding="9,4" Margin="0,0,7,0" ToolTip="Select two or more sessions with Ctrl or Shift."/><Button Content="Open folder" Click="Folder_Click" Padding="9,4" Margin="0,0,7,0"/><Button Content="Export session" Click="Export_Click" Padding="9,4" Margin="0,0,7,0"/><Button Content="Delete session…" Click="Delete_Click" Padding="9,4"/></WrapPanel>
    </Grid></Border>
  </Grid>
</Window>
