<Window x:Class="XRViewLab.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="XR ViewLab"
        Width="540"
        Height="660"
        MinWidth="540"
        MinHeight="660"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="#E8E8E8"
        FontFamily="Segoe UI"
        FontSize="14">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="7" GlassFrameThickness="0" CornerRadius="10"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#171819"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#101112"/>
        <SolidColorBrush x:Key="PanelRaisedBrush" Color="#161719"/>
        <SolidColorBrush x:Key="InputBrush" Color="#080909"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#2B2D31"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#9A9A9A"/>
        <SolidColorBrush x:Key="RedBrush" Color="#C90012"/>
        <SolidColorBrush x:Key="BlueButtonBrush" Color="#1A2637"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8E8"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBrush}"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#3A3D42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="CaretBrush" Value="#E8E8E8"/>
            <Setter Property="MinWidth" Value="96"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BlueButtonBrush}"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#29364A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#253A55"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#C90012"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource RedBrush}"/>
            <Setter Property="BorderBrush" Value="#EC3038"/>
            <Setter Property="MinWidth" Value="112"/>
        </Style>

        <Style x:Key="TitleButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B8B8B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#24262A"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#C90012"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterLink" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#8F8F8F"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F4C542"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Foreground" Value="#FFE17A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SliderTrackButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}" Height="4" CornerRadius="2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#090A0B"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#2B2D31"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Row"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#202226"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#35383D"/>
                                <Setter TargetName="Row" Property="BorderBrush" Value="#86888C"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Row" Property="Background" Value="#3E4248"/>
                                <Setter Property="Foreground" Value="#E8E8E8"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="26">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderTrackButton}" Background="#C90012"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource SliderTrackButton}" Background="#2B2D31"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#E02A35"
                                                        BorderBrush="#FF5960"
                                                        BorderThickness="1"
                                                        CornerRadius="7"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Width="6"
                                Margin="0,3"
                                HorizontalAlignment="Center"
                                Background="#80A7A7A7"
                                CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="0,10">
                                <Track.Thumb>
                                    <Thumb/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>

        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Column="0"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Style="{StaticResource DarkScrollBar}"
                                       Orientation="Vertical"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Background" Value="#161719"/>
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="BorderBrush" Value="#2B2D31"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border Background="#161719"
                                BorderBrush="#2B2D31"
                                BorderThickness="0,0,1,1">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="8,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource ShellBrush}" BorderBrush="#303236" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="34"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#101112" CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="XR VIEWLAB" Margin="18,0,0,0" VerticalAlignment="Center" Foreground="#8D8F94" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Content="-" Width="46" Style="{StaticResource TitleButton}" Click="Minimize_Click"/>
                        <Button Content="X" Width="50" Style="{StaticResource TitleButton}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
                <StackPanel Margin="34,28,34,28">
                    <TextBlock Text="XR ViewLab" FontSize="30" FontWeight="Light"/>
                    <TextBlock Text="Configure OpenXR render height and per-application profiles." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,24"/>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="16" Margin="0,0,0,22">
                        <CheckBox x:Name="EnabledCheck"
                                  Content="Enable XR ViewLab"
                                  Checked="EnabledCheck_Changed"
                                  Unchecked="EnabledCheck_Changed"/>
                    </Border>

                    <TextBlock Text="RENDER HEIGHT" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="20" Margin="0,0,0,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Total" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBox x:Name="TotalBox" Grid.Row="0" Grid.Column="1" TextChanged="RenderValue_Changed"/>
                            <TextBlock x:Name="TotalHint" Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                            <Slider x:Name="TotalSlider" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Minimum="0.01" Maximum="1" ValueChanged="RenderSlider_Changed"/>

                            <CheckBox x:Name="SplitCheck" Grid.Row="4" Grid.ColumnSpan="3" Content="Split top and bottom" Checked="SplitCheck_Changed" Unchecked="SplitCheck_Changed"/>

                            <TextBlock Grid.Row="6" Text="Top" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBox x:Name="TopBox" Grid.Row="6" Grid.Column="1" TextChanged="RenderValue_Changed"/>
                            <TextBlock x:Name="TopHint" Grid.Row="6" Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                            <Slider x:Name="TopSlider" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3" Minimum="0" Maximum="1" ValueChanged="RenderSlider_Changed"/>

                            <TextBlock Grid.Row="10" Text="Bottom" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBox x:Name="BottomBox" Grid.Row="10" Grid.Column="1" TextChanged="RenderValue_Changed"/>
                            <TextBlock x:Name="BottomHint" Grid.Row="10" Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                            <Slider x:Name="BottomSlider" Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="3" Minimum="0" Maximum="1" ValueChanged="RenderSlider_Changed"/>

                            <TextBlock Grid.Row="14" Text="Horizontal" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBox x:Name="HorizontalBox" Grid.Row="14" Grid.Column="1" TextChanged="RenderValue_Changed"/>
                            <TextBlock x:Name="HorizontalHint" Grid.Row="14" Grid.Column="3" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                            <Slider x:Name="HorizontalSlider" Grid.Row="16" Grid.Column="1" Grid.ColumnSpan="3" Minimum="0.01" Maximum="1" ValueChanged="RenderSlider_Changed"/>

                            <TextBlock x:Name="CombinedHint" Grid.Row="18" Grid.ColumnSpan="4" Foreground="{StaticResource MutedBrush}"/>
                            <CheckBox x:Name="FoveatedCenterCheck"
                                      Grid.Row="20"
                                      Grid.ColumnSpan="3"
                                      Content="Fovea centering"
                                      Foreground="#A8A8A8"/>
                            <Button Grid.Row="22" Grid.ColumnSpan="3" Content="Save" Style="{StaticResource RedButton}" HorizontalAlignment="Left" Click="Save_Click"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="APPLICATIONS" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="14" Margin="0,0,0,22">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="260"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Checked apps use XR ViewLab. Unchecked apps bypass it." Foreground="{StaticResource MutedBrush}"/>
                            <ListView x:Name="AppsList"
                                      Grid.Row="2"
                                      SizeChanged="List_SizeChanged"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn x:Name="AppsCheckColumn" Width="54">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding AppEnabled, Mode=TwoWay}" Checked="AppEnabled_Changed" Unchecked="AppEnabled_Changed"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn x:Name="AppsNameColumn" Header="Application" DisplayMemberBinding="{Binding Display}" Width="520"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <Button Grid.Row="4" Content="Reload apps" Style="{StaticResource RedButton}" HorizontalAlignment="Left" Click="ReloadApps_Click"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="APP PROFILES" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="300"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Double-click an enabled app to set custom values." Foreground="{StaticResource MutedBrush}"/>
                            <ListView x:Name="ProfilesList"
                                      Grid.Row="2"
                                      MouseDoubleClick="ProfilesList_DoubleClick"
                                      SizeChanged="List_SizeChanged"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn x:Name="ProfilesNameColumn" Header="Application" DisplayMemberBinding="{Binding DisplayName}" Width="420"/>
                                        <GridViewColumn x:Name="ProfilesValueColumn" Header="Values" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Summary}" Foreground="#D8D8D8"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                            <Button Grid.Row="4"
                                    Content="Reset app"
                                    Style="{StaticResource RedButton}"
                                    HorizontalAlignment="Left"
                                    Click="ResetApp_Click"/>
                        </Grid>
                    </Border>
                    <TextBlock Text="Thanks to Beta Testers: Kinder"
                               HorizontalAlignment="Right"
                               Foreground="#5F6064"
                               FontSize="12"
                               Margin="0,14,4,0"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#0A0B0C" BorderBrush="#222428" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10">
                <Grid Margin="18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="StatusText"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="2"
                            Content="Support the broke loser who made this app"
                            Style="{StaticResource FooterLink}"
                            Click="Support_Click">
                        <Button.Foreground>
                            <SolidColorBrush Color="#8F8F8F"/>
                        </Button.Foreground>
                        <Button.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <ColorAnimation Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                                                        To="#F4C542"
                                                        Duration="0:0:5"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Button.Triggers>
                    </Button>
                    <Button Grid.Column="4"
                            Content="Check for updates"
                            Style="{StaticResource FooterLink}"
                            Click="CheckUpdates_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
