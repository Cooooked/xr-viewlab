                            <TextBlock Text="R" VerticalAlignment="Center"/><Slider Name="IRacingSpotterRedSlider" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Tag="255" ValueChanged="IRacingSpotterRgb_Changed" MouseRightButtonUp="SliderResetToTag_RightClick" ToolTip="Red 0-255. Right-click to reset."/><TextBlock Grid.Column="2" Text="{Binding ElementName=IRacingSpotterRedSlider, Path=Value, StringFormat={}{0:0}}" TextAlignment="Right" VerticalAlignment="Center"/>
                          </Grid>
                          <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions><TextBlock Text="G" VerticalAlignment="Center"/><Slider Name="IRacingSpotterGreenSlider" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Tag="69" ValueChanged="IRacingSpotterRgb_Changed" MouseRightButtonUp="SliderResetToTag_RightClick" ToolTip="Green 0-255. Right-click to reset."/><TextBlock Grid.Column="2" Text="{Binding ElementName=IRacingSpotterGreenSlider, Path=Value, StringFormat={}{0:0}}" TextAlignment="Right" VerticalAlignment="Center"/></Grid>
                          <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions><TextBlock Text="B" VerticalAlignment="Center"/><Slider Name="IRacingSpotterBlueSlider" Grid.Column="1" Minimum="0" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True" Tag="0" ValueChanged="IRacingSpotterRgb_Changed" MouseRightButtonUp="SliderResetToTag_RightClick" ToolTip="Blue 0-255. Right-click to reset."/><TextBlock Grid.Column="2" Text="{Binding ElementName=IRacingSpotterBlueSlider, Path=Value, StringFormat={}{0:0}}" TextAlignment="Right" VerticalAlignment="Center"/></Grid>
                          <WrapPanel Margin="0,3,0,0">
                            <Border Name="IRacingSpotterColorPreview" Width="20" Height="20" Background="#FF4500" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,6,0" />
                            <TextBox Name="IRacingSpotterColorBox" Width="90" Text="FF4500" ToolTip="Hex RRGGBB" />
                            <Button Content="Apply colour" Style="{StaticResource RedButton}" Padding="8,2" Margin="6,0,0,0" Click="IRacingSpotterColor_Apply" />
                          </WrapPanel>

                          <TextBlock Text="Flag State Border" Foreground="#C08A2A" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,0" />
                          <CheckBox Name="IRacingFlagBorderCheck" Content="Enable flag-state border" Foreground="#A8A8A8" Margin="0,3,0,0" Checked="IRacingControl_Changed" Unchecked="IRacingControl_Changed" />
                          <TextBlock Text="Border width" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,3,0,0" />
                          <Slider Name="IRacingFlagWidthSlider" Minimum="0.003" Maximum="0.12" Value="0.018" Tag="0.018" ValueChanged="IRacingControlSlider_Changed" MouseRightButtonUp="SliderResetToTag_RightClick" ToolTip="Right-click to reset." />
                          <TextBlock Text="Border opacity" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,3,0,0" />
                          <Slider Name="IRacingFlagOpacitySlider" Minimum="0.05" Maximum="1" Value="0.6" Tag="0.6" ValueChanged="IRacingControlSlider_Changed" MouseRightButtonUp="SliderResetToTag_RightClick" ToolTip="Right-click to reset." />

                          <TextBlock Text="Low Fuel Warning" Foreground="#C08A2A" FontSize="10" FontWeight="SemiBold" Margin="0,8,0,0" />
                          <CheckBox Name="IRacingFuelWarningCheck" Content="Enable low fuel warning card" Foreground="#A8A8A8" Margin="0,3,0,0" Checked="IRacingControl_Changed" Unchecked="IRacingControl_Changed" ToolTip="Fires once per crossing below the threshold, from the SDK's FuelLevelPct — absent on cars/tracks that don't report it." />
                          <TextBlock Text="Fuel threshold (%)" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,3,0,0" />
                          <Slider Name="IRacingFuelWarningThresholdSlider" Minimum="1" Maximum="50" Value="10" Tag="10" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="IRacingControlSlider_Changed" MouseRightButtonUp="SliderResetToTag_RightClick" ToolTip="Right-click to reset." />

                          <TextBlock Text="Presentation tests (no live connection required)" Foreground="{StaticResource MutedBrush}" FontSize="10" Margin="0,8,0,2" />
                          <WrapPanel><Button Content="Left" Style="{StaticResource RedButton}" Padding="6,2" Click="IRacingTestLeft_Click" /><Button Content="Right" Style="{StaticResource RedButton}" Padding="6,2" Margin="4,0,0,0" Click="IRacingTestRight_Click" /><Button Content="Both" Style="{StaticResource RedButton}" Padding="6,2" Margin="4,0,0,0" Click="IRacingTestBoth_Click" /><Button Content="Clear" Style="{StaticResource RedButton}" Padding="6,2" Margin="4,0,0,0" Click="IRacingTestClear_Click" /></WrapPanel>
                          <WrapPanel Margin="0,4,0,0"><Button Content="Lap" Style="{StaticResource RedButton}" Padding="6,2" Click="IRacingTestLap_Click" /><Button Content="Yellow" Style="{StaticResource RedButton}" Padding="6,2" Margin="4,0,0,0" Click="IRacingTestYellow_Click" /><Button Content="Blue" Style="{StaticResource RedButton}" Padding="6,2" Margin="4,0,0,0" Click="IRacingTestBlue_Click" /></WrapPanel>
                        </StackPanel>
                      </Expander>

                      <Separator Margin="0,8,0,7" Background="{StaticResource BorderBrush}" Height="1" />
                      <CheckBox Name="ExperimentalDrawInVoidCheck" Content="Experimental: Draw in Void" Foreground="#C08A2A" Checked="ExperimentalDrawInVoid_Changed" Unchecked="ExperimentalDrawInVoid_Changed" ToolTip="Persists a future rendering-route request. No outside-crop renderer is implemented yet; off preserves the current path exactly." />

                      <Separator Margin="0,8,0,7" Background="{StaticResource BorderBrush}" Height="1" />
                      <TextBlock Text="SHOW IN OBS MIRROR" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,3" />
                      <TextBlock Text="Choose which ViewLab visuals are included in the OBS/mirror output. Headset visibility is unchanged." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="9" Margin="0,0,0,4" />
                      <CheckBox Name="ObsMirrorVisorCheck" Content="Visor Mask" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorClockCheck" Content="Clock" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorNotificationsCheck" Content="Notifications" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorHudCheck" Content="Performance HUD" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorTraceCheck" Content="Performance Trace" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorCrosshairCheck" Content="Crosshair" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorStickyCheck" Content="Sticky Notes" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorRecordingCueCheck" Content="OBS Recording Cue" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorRacingCheck" Content="iRacing Telemetry" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <CheckBox Name="ObsMirrorBoundaryCheck" Content="Boundary Flash" Foreground="#A8A8A8" Margin="0,2,0,0" Checked="ObsMirrorVisibility_Changed" Unchecked="ObsMirrorVisibility_Changed" />
                      <Separator Margin="0,8,0,7" Background="{StaticResource BorderBrush}" Height="1" />
                      <TextBlock Text="VIEWLAB MIRROR OBS PLUGIN" Foreground="{StaticResource MutedBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,3" />
                      <TextBlock Text="ViewLab's own OBS source plugin (early skeleton). Installs per user into %APPDATA%\obs-studio\plugins; no OBS process is launched or controlled." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="9" Margin="0,0,0,4" />
                      <Button Name="InstallViewLabMirrorPluginButton" Content="Install ViewLab Mirror Plugin" Padding="9,4" HorizontalAlignment="Left" Click="InstallViewLabMirrorPlugin_Click" />
                      <TextBlock Name="ViewLabMirrorPluginStatusText" Text="" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="9" Margin="0,4,0,0" />
                      </StackPanel>
                    </StackPanel>
                  </ScrollViewer>
                </Border>
              </Popup>
              <Popup Name="VrQuadPopup" StaysOpen="False" AllowsTransparency="True" Closed="VrQuadPopup_Closed">
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" MaxHeight="500">
                  <ScrollViewer>
                    <StackPanel>
                      <TextBlock Text="VR QUAD" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                      <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,6" />
                      <TextBlock Text="POSITION" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                      <Grid HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Content="↖" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="-1,-1"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="↑" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="0,-1"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="↗" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="1,-1"/>
                        <Button Grid.Row="1" Grid.Column="0" Content="←" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="-1,0"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="●" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="11" Click="VrQuadDir_Click" Tag="0,0"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="→" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="1,0"/>
                        <Button Grid.Row="2" Grid.Column="0" Content="↙" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="-1,1"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="↓" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="0,1"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="↘" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="1,1"/>
                      </Grid>
                      <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Near" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrDistSlider" Minimum="0.3" Maximum="5" SmallChange="0.01" LargeChange="0.1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrDistVal" Text="1.50" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,6" />
                      <TextBlock Text="SIZE" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                      <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Width" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrWidthSlider" Minimum="0.1" Maximum="3" SmallChange="0.01" LargeChange="0.1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrWidthVal" Text="0.50" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Height" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrHeightSlider" Minimum="0.1" Maximum="2" SmallChange="0.01" LargeChange="0.1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrHeightVal" Text="0.50" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Scale" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrScaleSlider" Minimum="0.1" Maximum="3" SmallChange="0.01" LargeChange="0.1" Value="1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrScaleVal" Text="1.00" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,6" />
                      <TextBlock Text="APPEARANCE" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                      <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Rotate" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrRotSlider" Minimum="-180" Maximum="180" SmallChange="0.5" LargeChange="5" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrRotVal" Text="0.0" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Alpha" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrAlphaSlider" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrAlphaVal" Text="1.00" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Reset" Padding="6,3" Style="{StaticResource RedButton}" Margin="2" Click="VrQuadReset_Click" />
                        <Button Grid.Column="1" Content="Default" Padding="6,3" Style="{StaticResource RedButton}" Margin="2" Click="VrQuadSaveDefault_Click" />
                        <Button Grid.Column="2" Content="Close" Padding="6,3" Style="{StaticResource RedButton}" Margin="2" Click="VrQuadClose_Click" />
                      </Grid>
                    </StackPanel>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Canvas>
            <StackPanel Name="SidePanel" Grid.Row="8">
              <TextBlock Name="AppsHeader" Visibility="Collapsed" Height="0" Margin="0" />
              <Border Name="AppsCard" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition x:Name="AppsGridRow" Height="180" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Checked apps use ViewLab. Double-click for per-game customization." Foreground="{StaticResource MutedBrush}" />
                  <Grid Grid.Row="2">
                    <DataGrid Name="AppsGrid" IsReadOnly="False" CanUserResizeColumns="True" MouseDoubleClick="AppsGrid_DoubleClick" PreviewKeyDown="AppsGrid_KeyDown">
                      <DataGrid.Columns>
                        <DataGridTemplateColumn x:Name="AppsCheckColumn" Header="" Width="28" MinWidth="24" MaxWidth="52" CanUserResize="True">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource TableCheckBox}" IsChecked="{Binding AppEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Click="AppEnabled_Click" />
                              </Grid>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn x:Name="AppsNameColumn" Header="Application" ElementStyle="{StaticResource GridTextCell}" Width="*" MinWidth="80" IsReadOnly="True" CanUserResize="True" Binding="{Binding Display}" />
                        <DataGridTextColumn x:Name="AppsValueColumn" Header="Values" ElementStyle="{StaticResource GridValueCell}" Width="62" MinWidth="36" CanUserResize="True" Binding="{Binding Summary}" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="AppsXrTypeColumn" Header="XR" ElementStyle="{StaticResource GridValueCell}" Width="42" MinWidth="28" CanUserResize="True" Binding="{Binding XrType}" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="AppsStatusColumn" Header="Status" ElementStyle="{StaticResource GridValueCell}" Width="66" MinWidth="52" CanUserResize="True" Binding="{Binding HookStatus}" IsReadOnly="True" />
                      </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Name="AppsEmptyText" Text="No apps detected yet.&#x0a;Launch a VR game, reload apps, or add the game exe." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False" />
                  </Grid>
                  <WrapPanel Grid.Row="4">
                    <Button Content="Reload apps" Style="{StaticResource RedButton}" Margin="0,0,8,0" Click="ReloadApps_Click" />
                    <Button Content="Add app" Style="{StaticResource RedButton}" Margin="0,0,8,0" Click="AddApp_Click" />
                    <Button Content="Reset profile" Style="{StaticResource RedButton}" Margin="0,0,8,0" Click="ResetApp_Click" />
                    <CheckBox Name="ShowHiddenAppsCheck" Content="Show hidden" VerticalAlignment="Center" Checked="ShowHiddenApps_Changed" Unchecked="ShowHiddenApps_Changed" />
                  </WrapPanel>
                </Grid>
              </Border>
              <TextBlock Name="ReShadeOpenXRHeader" Text="ReShade Remote" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,5" />
              <Border Name="ReShadeOpenXRCard" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                  <Button Content="ReShade ▾" Style="{StaticResource RedButton}" HorizontalAlignment="Left" Padding="10,4" ToolTip="Optional ReShade controls. ViewLab crop and masks still work without ReShade." Click="OpenReShadeRemote_Click" />
                </StackPanel>
              </Border>
              <TextBlock Name="ThanksText" Text="Thanks to Beta Testers: Kinder, hkguy6" HorizontalAlignment="Right" Foreground="#5F6064" FontSize="12" Margin="0,6,4,4" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
      <Border Grid.Row="2" Background="#0A0B0C" BorderBrush="#222428" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10">
        <Grid Name="FooterGrid" Margin="6,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Name="FooterVersionCol" Width="Auto" />
            <ColumnDefinition Name="FooterGap1" Width="6" />
            <ColumnDefinition Name="FooterStatusCol" Width="*" />
            <ColumnDefinition Name="FooterGap2" Width="6" />
            <ColumnDefinition Name="FooterLogCol" Width="Auto" />
            <ColumnDefinition Name="FooterGap2b" Width="6" />
            <ColumnDefinition Name="FooterDiagCol" Width="Auto" />
            <ColumnDefinition Name="FooterGap3" Width="6" />
            <ColumnDefinition Name="FooterSupportCol" Width="Auto" />
            <ColumnDefinition Name="FooterGap4" Width="6" />
            <ColumnDefinition Name="FooterUpdCol" Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Name="VersionText" Grid.Column="0" VerticalAlignment="Center" Foreground="#6F7074" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
          <TextBlock Name="StatusText" Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
          <TextBlock Name="OpenLogButton" Grid.Column="4" Text="Log" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="4,0" Cursor="Hand" ToolTip="Open ViewLab.log" MouseLeftButtonUp="OpenLog_Click">
            <TextBlock.Foreground><SolidColorBrush Color="#8F8F8F" /></TextBlock.Foreground>
          </TextBlock>
          <TextBlock Name="WhatHappenedButton" Grid.Column="6" Text="What happened?" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="4,0" Cursor="Hand" ToolTip="Explains the most recent ViewLab failure, if any, in plain language." MouseLeftButtonUp="WhatHappened_Click">
            <TextBlock.Foreground><SolidColorBrush Color="#8F8F8F" /></TextBlock.Foreground>
          </TextBlock>
          <TextBlock Name="SupportFooterTextBlock" Grid.Column="8" Text="Support" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="6,0" Cursor="Hand" ToolTip="Support the broke loser who made this app" MouseLeftButtonUp="Support_Click">
            <TextBlock.Foreground><SolidColorBrush Color="#8F8F8F" /></TextBlock.Foreground>
            <FrameworkElement.Triggers>
              <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                  <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <ColorAnimation Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" To="#F4C542" Duration="0:0:5" />
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </FrameworkElement.Triggers>
          </TextBlock>
          <TextBlock Name="UpdatesButton" Grid.Column="10" Text="Update" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="4,0" Cursor="Hand" ToolTip="Check for updates" MouseLeftButtonUp="CheckUpdates_Click">
            <TextBlock.Foreground><SolidColorBrush Color="#8F8F8F" /></TextBlock.Foreground>
          </TextBlock>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
