                              <Expander Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Header="⚙ Warning thresholds" Foreground="#999" FontSize="9" Margin="5,2,0,3">
                                <Grid Margin="0,3,0,2">
