                      <CheckBox Name="CalGridCheck" Content="64 px texture grid" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Measures geometry and texture-edge distortion." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalRulerCheck" Content="Pixel ruler" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Counts exact pixels in a capture." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalGratingsCheck" Content="Resolution gratings" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Shows where 1, 2, and 4 pixel detail stops resolving." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalBarsCheck" Content="Colour bars + grey ramp" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Checks chroma damage and visible banding." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalBeaconCheck" Content="Frame beacon" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Flashes every submitted frame; exposes frame synthesis." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalEdgeProbesCheck" Content="Edge probes" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Tests blur and foveation directly at eye-texture edges." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalCheckerboardsCheck" Content="Checkerboard ladder" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Reveals scaling blur, compression loss, and moire." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalZonePlateCheck" Content="Radial spokes / zone plate" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Reveals uneven sharpness and aliasing." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalClippingCheck" Content="Black / white clipping steps" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Reveals crushed blacks and clipped whites." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <CheckBox Name="CalMotionCheck" Content="Motion strip" Foreground="#A8A8A8" ToolTip="Reveals temporal smearing and reprojection artefacts." Checked="CalibrationCheck_Changed" Unchecked="CalibrationCheck_Changed" />
                      <Separator Margin="0,9,0,7" Background="{StaticResource BorderBrush}" Height="1" />
                      <Button Name="RunCalibrationSuiteButton" Content="Run Calibration Suite (Experimental)" Style="{StaticResource RedButton}" Padding="9,4" Click="RunCalibrationSuite_Click" />
                      <TextBlock Text="Captures each pattern from the real submitted left-eye image while a game is running. Images and metadata save under %LOCALAPPDATA%\XR ViewLab\CalibrationCaptures. Your previous calibration settings are restored afterwards." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="9" Margin="0,4,0,0" />
