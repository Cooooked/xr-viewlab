                  </ScrollViewer>
                </Border>
              </Popup>
              <Popup Name="PreviewPopup" StaysOpen="False" AllowsTransparency="True">
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10">
