<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="XRViewLab.UI.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework" Title="ViewLab" Width="330" Height="390" MinWidth="190" MinHeight="280" WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="True" Background="#00FFFFFF" Foreground="#E8E8E8" FontFamily="Segoe UI" FontSize="14" xmlns:ui="clr-namespace:XRViewLab.UI">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="7" GlassFrameThickness="0" CornerRadius="10" />
  </shell:WindowChrome.WindowChrome>
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="ShellBrush" Color="#171819" />
      <SolidColorBrush x:Key="PanelBrush" Color="#101112" />
      <SolidColorBrush x:Key="PanelRaisedBrush" Color="#161719" />
      <SolidColorBrush x:Key="InputBrush" Color="#080909" />
      <SolidColorBrush x:Key="BorderBrush" Color="#2B2D31" />
      <SolidColorBrush x:Key="MutedBrush" Color="#9A9A9A" />
      <SolidColorBrush x:Key="RedBrush" Color="#C90012" />
      <SolidColorBrush x:Key="BlueButtonBrush" Color="#1A2637" />
      <Style x:Key="{x:Type TextBlock}" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#E8E8E8" />
      </Style>
      <Style x:Key="{x:Type TextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource InputBrush}" />
        <Setter Property="Foreground" Value="#E8E8E8" />
        <Setter Property="BorderBrush" Value="#3A3D42" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="TextBoxBase.CaretBrush" Value="#E8E8E8" />
        <Setter Property="MinWidth" Value="60" />
      </Style>
      <Style x:Key="{x:Type Button}" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource BlueButtonBrush}" />
        <Setter Property="Foreground" Value="#E8E8E8" />
        <Setter Property="BorderBrush" Value="#29364A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Root" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="3">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Root" Property="Border.Background" Value="#253A55" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Root" Property="Border.Background" Value="#C90012" />
                </Trigger>
                <Trigger Property="UIElement.IsEnabled" Value="False">
                  <Setter TargetName="Root" Property="Border.Background" Value="#303236" />
                  <Setter TargetName="Root" Property="Border.BorderBrush" Value="#45474B" />
                  <Setter Property="Foreground" Value="#8A8C90" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="RedButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource RedBrush}" />
        <Setter Property="BorderBrush" Value="#EC3038" />
        <Setter Property="MinWidth" Value="112" />
      </Style>
      <Style x:Key="TitleButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="Foreground" Value="#B8B8B8" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Root" Background="{TemplateBinding Control.Background}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Root" Property="Border.Background" Value="#24262A" />
                  <Setter Property="Foreground" Value="#E8E8E8" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Root" Property="Border.Background" Value="#C90012" />
                  <Setter Property="Foreground" Value="#E8E8E8" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="FooterLink" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="Foreground" Value="#8F8F8F" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Padding="{TemplateBinding Control.Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter Property="Foreground" Value="#F4C542" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter Property="Foreground" Value="#FFE17A" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type CheckBox}" TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="#D8D8D8" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
      </Style>
      <Style x:Key="TableCheckBox" TargetType="{x:Type CheckBox}">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type CheckBox}">
              <Grid Width="14" Height="14" Background="#00FFFFFF">
                <Border Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center" Background="#F1F1F1" BorderBrush="#F1F1F1" BorderThickness="1" />
                <Path Name="CheckMark" Data="M3,6 L5.4,8.5 L10,3.5" Stroke="#111111" StrokeThickness="2" StrokeStartLineCap="Square" StrokeEndLineCap="Square" Visibility="Collapsed" />
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="ToggleButton.IsChecked" Value="True">
                  <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="SliderTrackButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type RepeatButton}">
              <Border Background="{TemplateBinding Control.Background}" Height="4" CornerRadius="2" />
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type DataGrid}" TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="#090A0B" />
        <Setter Property="Foreground" Value="#E8E8E8" />
        <Setter Property="BorderBrush" Value="#2B2D31" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="DataGrid.AutoGenerateColumns" Value="False" />
        <Setter Property="DataGrid.CanUserAddRows" Value="False" />
        <Setter Property="DataGrid.CanUserDeleteRows" Value="False" />
        <Setter Property="DataGrid.CanUserResizeColumns" Value="True" />
        <Setter Property="DataGrid.GridLinesVisibility" Value="None" />
        <Setter Property="DataGrid.HeadersVisibility" Value="Column" />
        <Setter Property="DataGrid.HorizontalGridLinesBrush" Value="#00FFFFFF" />
        <Setter Property="DataGrid.VerticalGridLinesBrush" Value="#00FFFFFF" />
        <Setter Property="DataGrid.RowHeaderWidth" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="DataGrid.SelectionMode" Value="Single" />
        <Setter Property="DataGrid.SelectionUnit" Value="FullRow" />
      </Style>
      <Style x:Key="{x:Type DataGridColumnHeader}" TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="#161719" />
        <Setter Property="Foreground" Value="#D8D8D8" />
        <Setter Property="BorderBrush" Value="#2B2D31" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
      </Style>
      <Style x:Key="{x:Type DataGridRow}" TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="Foreground" Value="#E8E8E8" />
        <Setter Property="Height" Value="28" />
        <Style.Triggers>
          <Trigger Property="UIElement.IsMouseOver" Value="True">
            <Setter Property="Background" Value="#202226" />
          </Trigger>
          <Trigger Property="DataGridRow.IsSelected" Value="True">
            <Setter Property="Background" Value="#35383D" />
            <Setter Property="Foreground" Value="#E8E8E8" />
          </Trigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="{x:Type DataGridCell}" TargetType="{x:Type DataGridCell}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderBrush" Value="#00FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Foreground" Value="#E8E8E8" />
        <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
      </Style>
      <Style x:Key="GridTextCell" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#E8E8E8" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="6,0,0,0" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      </Style>
      <Style x:Key="ReShadePill" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#1A3A1A" />
        <Setter Property="BorderBrush" Value="#2A6A2A" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="5,1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="6,0,4,0" />
      </Style>
      <Style x:Key="GridValueCell" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource GridTextCell}">
        <Setter Property="Margin" Value="4,0,0,0" />
      </Style>
      <Style x:Key="{x:Type Slider}" TargetType="{x:Type Slider}">
        <Setter Property="RangeBase.Minimum" Value="0" />
        <Setter Property="RangeBase.Maximum" Value="1" />
        <Setter Property="RangeBase.LargeChange" Value="0.05" />
        <Setter Property="RangeBase.SmallChange" Value="0.01" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Slider}">
              <Grid Height="18">
                <Track Name="PART_Track">
                  <Track.DecreaseRepeatButton>
                    <RepeatButton Name="DecreaseTrackButton" Background="#C90012" Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource SliderTrackButton}" />
                  </Track.DecreaseRepeatButton>
                  <Track.IncreaseRepeatButton>
                    <RepeatButton Name="IncreaseTrackButton" Background="#2B2D31" Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource SliderTrackButton}" />
                  </Track.IncreaseRepeatButton>
                  <Track.Thumb>
                    <Thumb Width="12" Height="12">
                      <Control.Template>
                        <ControlTemplate TargetType="{x:Type Thumb}">
                          <Border Name="ThumbBorder" Background="#E02A35" BorderBrush="#FF5960" BorderThickness="1" CornerRadius="7" />
                          <ControlTemplate.Triggers>
                            <Trigger Property="UIElement.IsEnabled" Value="False">
                              <Setter TargetName="ThumbBorder" Property="Background" Value="#6A6C70" />
                              <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#8A8C90" />
                            </Trigger>
                          </ControlTemplate.Triggers>
                        </ControlTemplate>
                      </Control.Template>
                    </Thumb>
                  </Track.Thumb>
                </Track>
              </Grid>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsEnabled" Value="False">
                  <Setter TargetName="DecreaseTrackButton" Property="Control.Background" Value="#45474B" />
                  <Setter TargetName="IncreaseTrackButton" Property="Control.Background" Value="#25272A" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type Thumb}" TargetType="{x:Type Thumb}">
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Thumb}">
              <Border Width="6" Margin="0,3" HorizontalAlignment="Center" Background="#80A7A7A7" CornerRadius="4" />
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="DarkScrollBar" TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="Width" Value="6" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type ScrollBar}">
              <Grid Background="#00FFFFFF">
                <Track Name="PART_Track" IsDirectionReversed="True" Margin="0,10">
                  <Track.Thumb>
                    <Thumb />
                  </Track.Thumb>
                </Track>
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DarkScrollBar}" />
      <Style x:Key="DarkScrollViewer" TargetType="{x:Type ScrollViewer}">
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type ScrollViewer}">
              <Grid>
                <ScrollContentPresenter Name="PART_ScrollContentPresenter" Content="{TemplateBinding ContentControl.Content}" ContentTemplate="{TemplateBinding ContentControl.ContentTemplate}" CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}" />
                <ScrollBar Name="PART_VerticalScrollBar" HorizontalAlignment="Right" Orientation="Vertical" Visibility="{TemplateBinding ScrollViewer.ComputedVerticalScrollBarVisibility}" Maximum="{TemplateBinding ScrollViewer.ScrollableHeight}" ViewportSize="{TemplateBinding ScrollViewer.ViewportHeight}" Value="{TemplateBinding ScrollViewer.VerticalOffset}" Style="{StaticResource DarkScrollBar}" />
              </Grid>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Border Background="{StaticResource ShellBrush}" BorderBrush="#303236" BorderThickness="1" CornerRadius="10">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="42" />
        <RowDefinition Height="*" />
        <RowDefinition Height="30" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Background="#101112" CornerRadius="10,10,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid>
          <TextBlock Text="VIEWLAB" Margin="18,0,0,0" VerticalAlignment="Center" Foreground="#9C9EA4" FontWeight="SemiBold" FontSize="16" />
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button Content="-" Width="34" Style="{StaticResource TitleButton}" Click="Minimize_Click" />
            <Button Content="X" Width="38" Style="{StaticResource TitleButton}" Click="Close_Click" />
          </StackPanel>
        </Grid>
      </Border>
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Style="{StaticResource DarkScrollViewer}">
        <StackPanel Margin="12,10,12,10">
          <Grid Name="ContentGrid">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Name="MainColumn" Width="*" />
              <ColumnDefinition Name="WideGapColumn" Width="0" />
              <ColumnDefinition Name="SideColumn" Width="0" />
              <ColumnDefinition Name="WideGapColumn2" Width="0" />
              <ColumnDefinition Name="RightColumn" Width="0" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="10" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition x:Name="OptionsGapRow" Height="10" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="10" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Name="LeftColumnPanel" Grid.Column="0" Grid.Row="0" Grid.RowSpan="8" VerticalAlignment="Top">
            <Border Name="EnabledCard" CornerRadius="4" BorderThickness="2" Padding="10,8" Margin="0,0,0,10">
              <Border.BorderBrush>
                <SolidColorBrush x:Name="EnabledBorderBrush" Color="#C90012" />
              </Border.BorderBrush>
              <Border.Background>
                <SolidColorBrush x:Name="EnabledBgBrush" Color="#2A0008" />
              </Border.Background>
              <TextBlock Name="EnabledStatusText" Text="VIEWLAB DISABLED" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" MouseLeftButtonUp="EnabledCard_Click" Cursor="Hand">
                <TextBlock.Foreground>
                  <SolidColorBrush x:Name="EnabledStatusFg" Color="#C90012" />
                </TextBlock.Foreground>
              </TextBlock>
            </Border>
            <Border Name="RenderCard" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Name="RenderLabelColumn" Width="Auto" />
                  <ColumnDefinition Name="RenderLabelGapColumn" Width="8" />
                  <ColumnDefinition Name="RenderValueColumn" Width="100" />
                  <ColumnDefinition Name="RenderHintGapColumn" Width="10" />
                  <ColumnDefinition Name="RenderHintColumn" Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="2" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="6" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="6" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="2" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="6" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="2" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="6" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="2" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="6" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="6" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="4" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="0" />
                  <RowDefinition Height="0" />
                  <RowDefinition Height="0" />
                  <RowDefinition Height="0" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Vertical" VerticalAlignment="Center" FontWeight="SemiBold" ToolTip="How much vertical view the game renders. Keep this generous (around 0.40 for DiRT) to avoid LOD pop-in; use Visor Mask below for the visible border." />
                <TextBox Name="TotalBox" Grid.Row="0" Grid.Column="2" TextChanged="RenderValue_Changed" />
                <TextBlock Name="TotalHint" Grid.Row="0" Grid.Column="4" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                <Slider Name="TotalSlider" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3" Minimum="0.01" Maximum="1" ValueChanged="RenderSlider_Changed" />
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Horizontal" VerticalAlignment="Center" FontWeight="SemiBold" ToolTip="How much horizontal view the game renders. Keep this generous; use Visor Mask below for the visible border." />
                <TextBox Name="HorizontalBox" Grid.Row="4" Grid.Column="2" TextChanged="RenderValue_Changed" />
                <TextBlock Name="HorizontalHint" Grid.Row="4" Grid.Column="4" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                <Slider Name="HorizontalSlider" Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="3" Minimum="0.01" Maximum="1" ValueChanged="RenderSlider_Changed" />
                <CheckBox Name="SplitCheck" Grid.Row="8" Grid.ColumnSpan="5" Content="Split top and bottom" ToolTip="Use separate top and bottom render height values to move the rendered slice up or down." Checked="SplitCheck_Changed" Unchecked="SplitCheck_Changed" />
                <TextBlock Grid.Row="10" Grid.Column="0" Text="Top" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBox Name="TopBox" Grid.Row="10" Grid.Column="2" TextChanged="RenderValue_Changed" />
                <TextBlock Name="TopHint" Grid.Row="10" Grid.Column="4" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                <Slider Name="TopSlider" Grid.Row="12" Grid.Column="2" Grid.ColumnSpan="3" Minimum="0" Maximum="1" ValueChanged="RenderSlider_Changed" />
                <TextBlock Grid.Row="14" Grid.Column="0" Text="Bottom" VerticalAlignment="Center" FontWeight="SemiBold" />
                <TextBox Name="BottomBox" Grid.Row="14" Grid.Column="2" TextChanged="RenderValue_Changed" />
                <TextBlock Name="BottomHint" Grid.Row="14" Grid.Column="4" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                <Slider Name="BottomSlider" Grid.Row="16" Grid.Column="2" Grid.ColumnSpan="3" Minimum="0" Maximum="1" ValueChanged="RenderSlider_Changed" />
                <TextBlock Name="CombinedHint" Grid.Row="18" Grid.ColumnSpan="5" Foreground="{StaticResource MutedBrush}" />
                <CheckBox Name="EdgeSmearFixCheck" Grid.Row="20" Grid.ColumnSpan="5" Content="Experimental: edge-smear fix" Foreground="#A8A8A8" Margin="0,0,0,0" ToolTip="Draws small black guard bands into the submitted projection edges to stop runtimes sampling smeared edge texels." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                <CheckBox Name="LodPopInFixCheck" Grid.Row="22" Grid.ColumnSpan="5" Content="Experimental: LOD pop-in fix" Foreground="#A8A8A8" Margin="0,0,0,0" ToolTip="Diagnostic-only in this build; ViewLab still preserves the vertical and horizontal crop." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
              </Grid>
            </Border>
            <!-- Render Options: lives in LeftColumnPanel for single/two-col; moved to RightColumnPanel in 3-col by UpdateResponsiveLayout -->
            <TextBlock Name="OptionsHeader" Text="RENDER OPTIONS" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,10,0,5" />
            <Border Name="OptionsCard" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,0">
              <StackPanel>
                <CheckBox Name="FoveatedCenterCheck" Content="Center fovea on render slice" Foreground="#A8A8A8" Margin="0,0,0,4" ToolTip="Centers the game's foveated rendering circle on the rendered area." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                <CheckBox Name="StencilOuterEdgesCheck" Content="Stencil outer edges only" Foreground="#A8A8A8" Margin="0,0,0,4" ToolTip="Filters OpenXR hidden visibility-mask triangles so each eye keeps only its outer-side stencil. Works with Virtual Desktop's FOV stencil. Preview shows single-eye open-inner shape (nose/bridge) instead of closed bean." Checked="StencilOuterEdgesCheck_Changed" Unchecked="StencilOuterEdgesCheck_Changed" />
                <CheckBox Name="CropOuterEdgesCheck" Content="Crop outer edges only" Foreground="#A8A8A8" Margin="0,0,0,6" ToolTip="Crops only the outer edges of the render area instead of the full vertical slice." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                <Button Name="VisualMasksButton" Content="Edge Masks ▾" Style="{StaticResource RedButton}" HorizontalAlignment="Left" Padding="10,4" ToolTip="Original flat-edge visual masks. These remain separate from the optional visor/scuba mask." Click="VisualMasksButton_Click" />
                <Separator Margin="0,9,0,8" Background="{StaticResource BorderBrush}" Height="1" />
                <CheckBox Name="MaskEnabledCheck" Content="Visor mask" Foreground="#A8A8A8" Margin="0,0,0,6" ToolTip="Draws a ViewLab-owned rounded visor." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                <CheckBox Name="VisorHDCheck" Content="HD visor (2x supersampling)" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Render visor at 2x resolution internally for better edge quality (higher GPU cost)." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                <CheckBox Name="VisorAntiAliasingCheck" Content="Anti-aliasing" Foreground="#A8A8A8" Margin="0,0,0,6" ToolTip="Enable additional anti-aliasing for smoother visor edges." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                <ui:BeanMaskEditor x:Name="MaskBeanEditor" Height="76" Margin="0,0,0,8" ShapeChanged="MaskBeanEditor_ShapeChanged" Focusable="True" ToolTip="Preview uses the same rounded aperture settings as the OpenXR D3D11 mask texture." />
                <Grid Margin="0,0,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Size" VerticalAlignment="Center" FontSize="12" />
                  <Slider Name="MaskOpeningSlider" Grid.Row="0" Grid.Column="1" Minimum="0.05" Maximum="1" ValueChanged="MaskOpeningSlider_Changed" MouseRightButtonUp="MaskSliderReset_RightClick" />
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Curve" VerticalAlignment="Center" FontSize="12" />
                  <Slider Name="MaskRoundnessSlider" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="1" ValueChanged="MaskRoundnessSlider_Changed" MouseRightButtonUp="MaskSliderReset_RightClick" />
                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Apex Y" VerticalAlignment="Center" FontSize="12" />
                  <Slider Name="MaskApexYSlider" Grid.Row="2" Grid.Column="1" Minimum="-0.5" Maximum="0.5" ValueChanged="MaskApexYSlider_Changed" MouseRightButtonUp="MaskSliderReset_RightClick" />
                  <TextBlock Grid.Row="3" Grid.Column="0" Text="Inner low" VerticalAlignment="Center" FontSize="12" />
                  <Slider Name="MaskInnerLowerSlider" Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="0.333" ValueChanged="MaskInnerLowerSlider_Changed" MouseRightButtonUp="MaskSliderReset_RightClick" />
                  <TextBlock Grid.Row="4" Grid.Column="0" Text="Bridge" VerticalAlignment="Center" FontSize="12" />
                  <Slider Name="MaskInnerBridgeSlider" Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="1" ValueChanged="MaskInnerBridgeSlider_Changed" MouseRightButtonUp="MaskSliderReset_RightClick" />
                  <TextBlock Grid.Row="5" Grid.Column="0" Text="Rise" VerticalAlignment="Center" FontSize="12" />
                  <Slider Name="MaskInnerBridgeRiseSlider" Grid.Row="5" Grid.Column="1" Minimum="0" Maximum="0.5" ValueChanged="MaskInnerBridgeRiseSlider_Changed" MouseRightButtonUp="MaskSliderReset_RightClick" />
                  <TextBlock Grid.Row="6" Grid.Column="0" Text="Peak X" VerticalAlignment="Center" FontSize="12" />
                  <Slider Name="MaskInnerBridgePeakXSlider" Grid.Row="6" Grid.Column="1" Minimum="0" Maximum="1" ValueChanged="MaskInnerBridgePeakXSlider_Changed" MouseRightButtonUp="MaskSliderReset_RightClick" />
                  <TextBlock Grid.Row="7" Grid.Column="0" Text="Steep" VerticalAlignment="Center" FontSize="12" />
                  <Slider Name="MaskInnerBridgeSteepnessSlider" Grid.Row="7" Grid.Column="1" Minimum="0" Maximum="1" ValueChanged="MaskInnerBridgeSteepnessSlider_Changed" MouseRightButtonUp="MaskSliderReset_RightClick" />
                  <Slider Name="MaskOffsetXSlider" Grid.Row="8" Grid.Column="1" Minimum="-1" Maximum="1" Visibility="Collapsed" />
                  <Slider Name="MaskOffsetYSlider" Grid.Row="9" Grid.Column="1" Minimum="-1" Maximum="1" Visibility="Collapsed" />
                </Grid>
                <TextBox Name="MaskVerticalBox" Visibility="Collapsed" />
                <TextBox Name="MaskHorizontalBox" Visibility="Collapsed" />
                <Slider Name="MaskVerticalSlider" Visibility="Collapsed" Minimum="0.01" Maximum="1" ValueChanged="MaskSlider_Changed" />
                <Slider Name="MaskHorizontalSlider" Visibility="Collapsed" Minimum="0.01" Maximum="1" ValueChanged="MaskSlider_Changed" />
                <CheckBox Name="MaskRoundedCheck" Visibility="Collapsed" />
              </StackPanel>
            </Border>
            </StackPanel>
            <!-- Right column: single StackPanel spanning all rows — not sized by left-col row heights -->
            <StackPanel Name="RightColumnPanel" Grid.Row="0" Grid.RowSpan="9" Grid.Column="4" Visibility="Collapsed">
              <!-- OptionsHeader and OptionsCard are injected here by UpdateResponsiveLayout in 3-col mode -->
              <TextBlock Name="ReShadeOpenXRHeader2" Text="ReShade Remote" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,5" />
              <Border Name="ReShadeOpenXRCard2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                  <Button Content="Remote ▾" Style="{StaticResource RedButton}" HorizontalAlignment="Left" Padding="10,4" ToolTip="Optional ReShade controls. ViewLab crop and masks still work without ReShade." Click="OpenReShadeRemote_Click" />
                </StackPanel>
              </Border>
            </StackPanel>
            <!-- Hidden checkboxes for Edge Masks (state lives here, popup will reference by name) -->
            <Canvas Width="0" Height="0" Grid.Row="0">
              <Popup Name="VisualMasksPopup" StaysOpen="False" AllowsTransparency="True">
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12,10">
                  <StackPanel>
                    <TextBlock Text="Horizontal edge mask" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <CheckBox Name="HorizVisualMaskBothCheck" Content="Both sides" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Applies a horizontal visual mask to both the inner and outer edges of each eye." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                    <CheckBox Name="HorizOuterEyeMaskCheck" Content="Outer-eye mask only (no pixel savings)" IsEnabled="False" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="One-sided edge masks are not wired in this build." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                    <CheckBox Name="HorizInnerEyeMaskCheck" Content="Inner-eye mask only (no pixel savings)" IsEnabled="False" Foreground="#A8A8A8" Margin="0,0,0,10" ToolTip="One-sided edge masks are not wired in this build." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                    <TextBlock Text="Vertical edge mask" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,5" />
                    <CheckBox Name="VertVisualMaskBothCheck" Content="Both sides" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="Applies a vertical visual mask to both the top and bottom edges of each eye." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                    <CheckBox Name="VertTopMaskCheck" Content="Top mask only" IsEnabled="False" Foreground="#A8A8A8" Margin="0,0,0,3" ToolTip="One-sided edge masks are not wired in this build." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                    <CheckBox Name="VertBottomMaskCheck" Content="Bottom mask only" IsEnabled="False" Foreground="#A8A8A8" ToolTip="One-sided edge masks are not wired in this build." Checked="ExperimentalCheck_Changed" Unchecked="ExperimentalCheck_Changed" />
                  </StackPanel>
                </Border>
              </Popup>
              <Popup Name="VrQuadPopup" StaysOpen="False" AllowsTransparency="True" Closed="VrQuadPopup_Closed">
                <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="12" MaxHeight="500">
                  <ScrollViewer>
                    <StackPanel>
                      <TextBlock Text="VR QUAD" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,6" />
                      <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,6" />
                      <TextBlock Text="POSITION" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                      <Grid HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Content="↖" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="-1,-1"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="↑" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="0,-1"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="↗" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="1,-1"/>
                        <Button Grid.Row="1" Grid.Column="0" Content="←" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="-1,0"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="●" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="11" Click="VrQuadDir_Click" Tag="0,0"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="→" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="1,0"/>
                        <Button Grid.Row="2" Grid.Column="0" Content="↙" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="-1,1"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="↓" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="0,1"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="↘" Width="32" Height="32" Margin="1" Style="{StaticResource RedButton}" FontSize="14" Click="VrQuadDir_Click" Tag="1,1"/>
                      </Grid>
                      <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Near" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrDistSlider" Minimum="0.3" Maximum="5" SmallChange="0.01" LargeChange="0.1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrDistVal" Text="1.50" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,6" />
                      <TextBlock Text="SIZE" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                      <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Width" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrWidthSlider" Minimum="0.1" Maximum="3" SmallChange="0.01" LargeChange="0.1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrWidthVal" Text="0.50" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Height" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrHeightSlider" Minimum="0.1" Maximum="2" SmallChange="0.01" LargeChange="0.1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrHeightVal" Text="0.50" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Scale" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrScaleSlider" Minimum="0.1" Maximum="3" SmallChange="0.01" LargeChange="0.1" Value="1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrScaleVal" Text="1.00" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Separator Background="{StaticResource BorderBrush}" Height="1" Margin="0,0,0,6" />
                      <TextBlock Text="APPEARANCE" Foreground="{StaticResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                      <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Rotate" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrRotSlider" Minimum="-180" Maximum="180" SmallChange="0.5" LargeChange="5" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrRotVal" Text="0.0" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Alpha" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,0,6,0"/>
                        <Slider Grid.Column="1" Name="VrAlphaSlider" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1" ValueChanged="VrQuadSlider_Changed"/>
                        <TextBlock Grid.Column="2" Name="VrAlphaVal" Text="1.00" TextAlignment="Right" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontSize="11" MinWidth="30" Margin="6,0,0,0"/>
                      </Grid>
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Reset" Padding="6,3" Style="{StaticResource RedButton}" Margin="2" Click="VrQuadReset_Click" />
                        <Button Grid.Column="1" Content="Default" Padding="6,3" Style="{StaticResource RedButton}" Margin="2" Click="VrQuadSaveDefault_Click" />
                        <Button Grid.Column="2" Content="Close" Padding="6,3" Style="{StaticResource RedButton}" Margin="2" Click="VrQuadClose_Click" />
                      </Grid>
                    </StackPanel>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Canvas>
            <StackPanel Name="SidePanel" Grid.Row="8">
              <TextBlock Name="AppsHeader" Text="APPLICATIONS" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,5" />
              <Border Name="AppsCard" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10">
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="5" />
                    <RowDefinition x:Name="AppsGridRow" Height="180" />
                    <RowDefinition Height="7" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Text="Checked apps use ViewLab. Double-click for per-game crop, visor, and render %." Foreground="{StaticResource MutedBrush}" />
                  <Grid Grid.Row="2">
                    <DataGrid Name="AppsGrid" IsReadOnly="False" CanUserResizeColumns="True" MouseDoubleClick="AppsGrid_DoubleClick" PreviewKeyDown="AppsGrid_KeyDown">
                      <DataGrid.Columns>
                        <DataGridTemplateColumn x:Name="AppsCheckColumn" Header="" Width="28" MinWidth="24" MaxWidth="52" CanUserResize="True">
                          <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                              <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource TableCheckBox}" IsChecked="{Binding AppEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Click="AppEnabled_Click" />
                              </Grid>
                            </DataTemplate>
                          </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn x:Name="AppsNameColumn" Header="Application" ElementStyle="{StaticResource GridTextCell}" Width="*" MinWidth="80" IsReadOnly="True" CanUserResize="True" Binding="{Binding Display}" />
                        <DataGridTextColumn x:Name="AppsValueColumn" Header="Values" ElementStyle="{StaticResource GridValueCell}" Width="62" MinWidth="36" CanUserResize="True" Binding="{Binding Summary}" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="AppsXrTypeColumn" Header="XR" ElementStyle="{StaticResource GridValueCell}" Width="42" MinWidth="28" CanUserResize="True" Binding="{Binding XrType}" IsReadOnly="True" />
                        <DataGridTextColumn x:Name="AppsStatusColumn" Header="Status" ElementStyle="{StaticResource GridValueCell}" Width="66" MinWidth="52" CanUserResize="True" Binding="{Binding HookStatus}" IsReadOnly="True" />
                      </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Name="AppsEmptyText" Text="No apps detected yet.&#x0a;Launch a VR game, reload apps, or add the game exe." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" Visibility="Collapsed" IsHitTestVisible="False" />
                  </Grid>
                  <WrapPanel Grid.Row="4">
                    <Button Content="Reload apps" Style="{StaticResource RedButton}" Margin="0,0,8,0" Click="ReloadApps_Click" />
                    <Button Content="Add app" Style="{StaticResource RedButton}" Margin="0,0,8,0" Click="AddApp_Click" />
                    <Button Content="Reset profile" Style="{StaticResource RedButton}" Margin="0,0,8,0" Click="ResetApp_Click" />
                    <CheckBox Name="ShowHiddenAppsCheck" Content="Show hidden" VerticalAlignment="Center" Checked="ShowHiddenApps_Changed" Unchecked="ShowHiddenApps_Changed" />
                  </WrapPanel>
                </Grid>
              </Border>
              <TextBlock Name="ReShadeOpenXRHeader" Text="ReShade Remote" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" Margin="0,0,0,5" />
              <Border Name="ReShadeOpenXRCard" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                  <Button Content="Remote ▾" Style="{StaticResource RedButton}" HorizontalAlignment="Left" Padding="10,4" ToolTip="Optional ReShade controls. ViewLab crop and masks still work without ReShade." Click="OpenReShadeRemote_Click" />
                </StackPanel>
              </Border>
              <TextBlock Name="ThanksText" Text="Thanks to Beta Testers: Kinder, hkguy6" HorizontalAlignment="Right" Foreground="#5F6064" FontSize="12" Margin="0,6,4,4" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </ScrollViewer>
      <Border Grid.Row="2" Background="#0A0B0C" BorderBrush="#222428" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10">
        <Grid Name="FooterGrid" Margin="6,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Name="FooterVersionCol" Width="Auto" />
            <ColumnDefinition Name="FooterGap1" Width="6" />
            <ColumnDefinition Name="FooterStatusCol" Width="*" />
            <ColumnDefinition Name="FooterGap2" Width="6" />
            <ColumnDefinition Name="FooterLogCol" Width="Auto" />
            <ColumnDefinition Name="FooterGap3" Width="6" />
            <ColumnDefinition Name="FooterSupportCol" Width="Auto" />
            <ColumnDefinition Name="FooterGap4" Width="6" />
            <ColumnDefinition Name="FooterUpdCol" Width="Auto" />
          </Grid.ColumnDefinitions>
          <TextBlock Name="VersionText" Grid.Column="0" VerticalAlignment="Center" Foreground="#6F7074" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
          <TextBlock Name="StatusText" Grid.Column="2" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}" />
          <TextBlock Name="OpenLogButton" Grid.Column="4" Text="Log" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="4,0" Cursor="Hand" ToolTip="Open ViewLab.log" MouseLeftButtonUp="OpenLog_Click">
            <TextBlock.Foreground><SolidColorBrush Color="#8F8F8F" /></TextBlock.Foreground>
          </TextBlock>
          <TextBlock Name="SupportFooterTextBlock" Grid.Column="6" Text="Support" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="6,0" Cursor="Hand" ToolTip="Support the broke loser who made this app" MouseLeftButtonUp="Support_Click">
            <TextBlock.Foreground><SolidColorBrush Color="#8F8F8F" /></TextBlock.Foreground>
            <FrameworkElement.Triggers>
              <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                  <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                    <ColorAnimation Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" To="#F4C542" Duration="0:0:5" />
                  </Storyboard>
                </BeginStoryboard>
              </EventTrigger>
            </FrameworkElement.Triggers>
          </TextBlock>
          <TextBlock Name="UpdatesButton" Grid.Column="8" Text="Update" VerticalAlignment="Center" HorizontalAlignment="Right" Padding="4,0" Cursor="Hand" ToolTip="Check for updates" MouseLeftButtonUp="CheckUpdates_Click">
            <TextBlock.Foreground><SolidColorBrush Color="#8F8F8F" /></TextBlock.Foreground>
          </TextBlock>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
