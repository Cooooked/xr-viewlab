<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="XR ViewLab"
           Language="1033" Version="2.2.0"
           Manufacturer="cooooked"
           UpgradeCode="1FD1263B-D12E-46C8-9B07-D0F4C1E7AD87">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <Property Id="ARPCOMMENTS" Value="Tunes OpenXR VR view/render height with total or split top/bottom controls" />
    <Property Id="REBOOT" Value="ReallySuppress" />
    <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />

    <Feature Id="Main" Title="XR ViewLab" Level="1">
      <ComponentRef Id="LayerFiles"/>
      <ComponentRef Id="AppFiles"/>
      <ComponentRef Id="RegEnable"/>
      <ComponentRef Id="StartMenuShortcut"/>
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="InstallDir" Name="openxr-verticaltangent">
          <Component Id="LayerFiles" Guid="A3E0E51C-45C2-45AA-B458-2F37F261C40A" Win64="yes">
            <File Id="LayerDll" Source="..\x64\Release\XR_APILAYER_cooooked_verticaltangent_overlaytest.dll" Name="XR_APILAYER_cooooked_verticaltangent.dll"/>
            <File Id="LayerJson" Source="..\XR_APILAYER_cooooked_verticaltangent.json" Name="XR_APILAYER_cooooked_verticaltangent.json"/>
            <File Id="ConfigFile" Source="..\openxr-verticaltangent.ini" Name="openxr-verticaltangent.ini"/>
            <RemoveFile Id="RemoveLayerDll" Name="XR_APILAYER_cooooked_verticaltangent.dll" On="uninstall"/>
            <RemoveFile Id="RemoveLayerJson" Name="XR_APILAYER_cooooked_verticaltangent.json" On="uninstall"/>
            <RemoveFile Id="RemoveConfigFile" Name="openxr-verticaltangent.ini" On="uninstall"/>
            <RemoveFile Id="RemoveLogFile" Name="openxr-verticaltangent.log" On="uninstall"/>
            <RemoveFolder Id="RemoveInstallDirFromLayerFiles" On="uninstall"/>
          </Component>
          <Component Id="AppFiles" Guid="B5EC7B3F-8094-43B8-A6B4-9E4D48B8281A" Win64="yes">
            <File Id="SettingsApp" Source="..\x64\Release\openxr-verticaltangent-overlaytest.exe" Name="openxr-verticaltangent.exe" KeyPath="yes"/>
            <RemoveFile Id="RemoveSettingsApp" Name="openxr-verticaltangent.exe" On="uninstall"/>
          </Component>
          <Component Id="RegEnable" Guid="7CFF3A28-702B-49EB-BD2C-CFD2B2A7FA77" Win64="yes">
            <RegistryValue Root="HKLM"
                           Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                           Name="[#LayerJson]"
                           Type="integer"
                           Value="0"
                           Action="write"
                           KeyPath="yes"/>
            <RemoveRegistryValue Root="HKLM"
                                 Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                                 Name="C:\Program Files\openxr-verticaltangent\XR_APILAYER_cooooked_verticaltangent.json"/>
            <RemoveRegistryValue Root="HKLM"
                                 Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                                 Name="C:\Program Files\openxr-verticaltangent-overlaytest\XR_APILAYER_cooooked_verticaltangent_overlaytest.json"/>
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="XR ViewLab">
          <Component Id="StartMenuShortcut" Guid="3AE9AB79-5298-4921-B099-9F98E8383356" Win64="yes">
            <Shortcut Id="StartMenuShortcut"
                      Name="XR ViewLab"
                      Description="Configure OpenXR VR view/render height"
                      Target="[#SettingsApp]"
                      WorkingDirectory="InstallDir"/>
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
            <RegistryValue Root="HKCU" Key="Software\cooooked\openxr-verticaltangent" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>
    </Directory>
  </Product>
</Wix>
