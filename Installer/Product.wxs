<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="XR ViewLab"
           Language="1033" Version="3.1.0"
           Manufacturer="cooooked"
           UpgradeCode="1FD1263B-D12E-46C8-9B07-D0F4C1E7AD87">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <Property Id="ARPCOMMENTS" Value="Tunes OpenXR VR render height and width" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
    <Property Id="REBOOT" Value="ReallySuppress" />
    <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />

    <Feature Id="Main" Title="XR ViewLab" Level="1">
      <ComponentRef Id="LayerFiles"/>
      <ComponentRef Id="AppFiles"/>
      <ComponentRef Id="RegEnable"/>
      <ComponentRef Id="StartMenuShortcut"/>
      <ComponentRef Id="DesktopShortcut"/>
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="InstallDir" Name="xr-viewlab">
          <Component Id="LayerFiles" Guid="A3E0E51C-45C2-45AA-B458-2F37F261C40A" Win64="yes">
            <File Id="LayerDll" Source="..\x64\Release\XR_APILAYER_cooooked_xrviewlab.dll" Name="XR_APILAYER_cooooked_xrviewlab.dll"/>
            <File Id="LayerJson" Source="..\XR_APILAYER_cooooked_xrviewlab.json" Name="XR_APILAYER_cooooked_xrviewlab.json"/>
            <File Id="ConfigFile" Source="..\xr-viewlab.ini" Name="xr-viewlab.ini"/>
            <RemoveFile Id="RemoveLayerDll" Name="XR_APILAYER_cooooked_xrviewlab.dll" On="uninstall"/>
            <RemoveFile Id="RemoveLayerJson" Name="XR_APILAYER_cooooked_xrviewlab.json" On="uninstall"/>
            <RemoveFile Id="RemoveConfigFile" Name="xr-viewlab.ini" On="uninstall"/>
            <RemoveFile Id="RemoveLogFile" Name="xr-viewlab.log" On="uninstall"/>
            <RemoveFile Id="RemoveOldLayerDll" Name="XR_APILAYER_cooooked_verticaltangent.dll" On="both"/>
            <RemoveFile Id="RemoveOldLayerJson" Name="XR_APILAYER_cooooked_verticaltangent.json" On="both"/>
            <RemoveFile Id="RemoveOldConfigFile" Name="openxr-verticaltangent.ini" On="both"/>
            <RemoveFile Id="RemoveOldLogFile" Name="openxr-verticaltangent.log" On="both"/>
            <RemoveFolder Id="RemoveInstallDirFromLayerFiles" On="uninstall"/>
          </Component>
          <Component Id="AppFiles" Guid="B5EC7B3F-8094-43B8-A6B4-9E4D48B8281A" Win64="yes">
            <File Id="SettingsApp" Source="..\XRViewLab.UI\bin\Release\net8.0-windows\win-x64\publish\xr-viewlab.exe" Name="xr-viewlab.exe" KeyPath="yes"/>
            <File Id="AppIconFile" Source="..\assets\xr-viewlab.ico" Name="xr-viewlab.ico"/>
            <RemoveFile Id="RemoveSettingsApp" Name="xr-viewlab.exe" On="uninstall"/>
            <RemoveFile Id="RemoveAppIconFile" Name="xr-viewlab.ico" On="uninstall"/>
            <RemoveFile Id="RemoveOldSettingsApp" Name="openxr-verticaltangent.exe" On="both"/>
          </Component>
          <Component Id="RegEnable" Guid="7CFF3A28-702B-49EB-BD2C-CFD2B2A7FA77" Win64="yes">
            <RegistryValue Root="HKLM"
                           Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                           Name="[#LayerJson]"
                           Type="integer"
                           Value="0"
                           Action="write"
                           KeyPath="yes"/>
            <RemoveRegistryValue Root="HKLM"
                                 Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                                 Name="C:\Program Files\xr-viewlab\XR_APILAYER_cooooked_xrviewlab.json"/>
            <RemoveRegistryValue Root="HKLM"
                                 Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                                 Name="C:\Program Files\openxr-verticaltangent\XR_APILAYER_cooooked_verticaltangent.json"/>
            <RemoveRegistryValue Root="HKLM"
                                 Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                                 Name="C:\Program Files\openxr-verticaltangent-overlaytest\XR_APILAYER_cooooked_verticaltangent_overlaytest.json"/>
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="XR ViewLab">
          <Component Id="StartMenuShortcut" Guid="3AE9AB79-5298-4921-B099-9F98E8383356" Win64="yes">
            <Shortcut Id="StartMenuShortcut"
                      Name="XR ViewLab"
                      Description="Configure OpenXR VR render height and width"
                      Target="[#SettingsApp]"
                      Icon="ProductIcon"
                      WorkingDirectory="InstallDir"/>
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
            <RegistryValue Root="HKCU" Key="Software\cooooked\xr-viewlab" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>
      <Directory Id="DesktopFolder">
        <Component Id="DesktopShortcut" Guid="9EC3A624-0467-4C5D-98AA-62BDB73F4C59" Win64="yes">
          <Condition>CREATE_DESKTOP_SHORTCUT=1</Condition>
          <Shortcut Id="DesktopShortcut"
                    Name="XR ViewLab"
                    Description="Configure OpenXR VR render height and width"
                    Target="[#SettingsApp]"
                    Icon="ProductIcon"
                    WorkingDirectory="InstallDir"/>
          <RegistryValue Root="HKCU" Key="Software\cooooked\xr-viewlab" Name="desktop_shortcut" Type="integer" Value="1" KeyPath="yes"/>
        </Component>
      </Directory>
    </Directory>
    <Icon Id="ProductIcon" SourceFile="..\assets\xr-viewlab.ico"/>
  </Product>
</Wix>
