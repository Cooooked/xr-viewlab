<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
  <Product Id="*" Name="XR ViewLab"
           Language="1033" Version="3.2.13"
           Manufacturer="cooooked"
           UpgradeCode="1FD1263B-D12E-46C8-9B07-D0F4C1E7AD87">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed." />
    <Property Id="ARPCOMMENTS" Value="Tunes OpenXR VR render height and width" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
    <Property Id="REBOOT" Value="ReallySuppress" />
    <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <util:CloseApplication Id="CloseXRViewLab"
                           Target="xr-viewlab.exe"
                           CloseMessage="yes"
                           RebootPrompt="no"
                           PromptToContinue="no"
                           Timeout="10" />
    <util:CloseApplication Id="CloseLegacyVerticalTangent"
                           Target="openxr-verticaltangent.exe"
                           CloseMessage="yes"
                           RebootPrompt="no"
                           PromptToContinue="no"
                           Timeout="10" />

    <Binary Id="CreateDesktopShortcutVbs" SourceFile="CreateDesktopShortcut.vbs" />
    <Binary Id="PreserveConfigVbs" SourceFile="PreserveConfig.vbs" />
    <CustomAction Id="PromptDesktopShortcut"
                  BinaryKey="CreateDesktopShortcutVbs"
                  VBScriptCall="PromptDesktopShortcut"
                  Execute="immediate"
                  Return="ignore" />
    <CustomAction Id="BackupConfig"
                  BinaryKey="PreserveConfigVbs"
                  VBScriptCall="BackupConfig"
                  Execute="immediate"
                  Return="ignore" />
    <CustomAction Id="CleanupApiLayerRegistry"
                  BinaryKey="PreserveConfigVbs"
                  VBScriptCall="CleanupApiLayerRegistry"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <UI>
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />
      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
      <Property Id="WixUI_Mode" Value="InstallDir" />

      <DialogRef Id="BrowseDlg" />
      <DialogRef Id="DiskCostDlg" />
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />

      <Publish Dialog="BrowseDlg" Control="OK" Event="DoAction" Value="WixUIValidatePath" Order="3">1</Publish>
      <Publish Dialog="BrowseDlg" Control="OK" Event="SpawnDialog" Value="InvalidDirDlg" Order="4"><![CDATA[NOT WIXUI_DONTVALIDATEPATH AND WIXUI_INSTALLDIR_VALID<>"1"]]></Publish>
      <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999">1</Publish>
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg">NOT Installed</Publish>
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg">Installed AND PATCH</Publish>
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="SetTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="DoAction" Value="WixUIValidatePath" Order="2">NOT WIXUI_DONTVALIDATEPATH</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="SpawnDialog" Value="InvalidDirDlg" Order="3"><![CDATA[NOT WIXUI_DONTVALIDATEPATH AND WIXUI_INSTALLDIR_VALID<>"1"]]></Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="4">WIXUI_DONTVALIDATEPATH OR WIXUI_INSTALLDIR_VALID="1"</Publish>
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Property="_BrowseProperty" Value="[WIXUI_INSTALLDIR]" Order="1">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Event="SpawnDialog" Value="BrowseDlg" Order="2">1</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" Order="1">NOT Installed</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2">Installed AND NOT PATCH</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2">Installed AND PATCH</Publish>
      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg">1</Publish>
      <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
      <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
      <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg">1</Publish>

      <Property Id="ARPNOMODIFY" Value="1" />
      <UIRef Id="WixUI_Common" />
      <UIRef Id="WixUI_ErrorProgressText" />
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="PromptDesktopShortcut" Order="1">NOT Installed</Publish>
    </UI>

    <Feature Id="Main" Title="XR ViewLab" Level="1">
      <ComponentRef Id="LayerFiles"/>
      <ComponentRef Id="AppFiles"/>
      <ComponentRef Id="RegEnable"/>
      <ComponentRef Id="StartMenuShortcut"/>
    </Feature>

    <InstallExecuteSequence>
      <Custom Action="BackupConfig" Before="RemoveFiles">1</Custom>
      <Custom Action="CleanupApiLayerRegistry" Before="InstallFinalize">1</Custom>
    </InstallExecuteSequence>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="xr-viewlab">
          <Component Id="LayerFiles" Guid="A3E0E51C-45C2-45AA-B458-2F37F261C40A" Win64="yes">
            <File Id="LayerDll" Source="..\x64\Release\XR_APILAYER_cooooked_xrviewlab.dll" Name="XR_APILAYER_cooooked_xrviewlab.dll"/>
            <File Id="LayerJson" Source="..\XR_APILAYER_cooooked_xrviewlab.json" Name="XR_APILAYER_cooooked_xrviewlab.json"/>
            <RemoveFile Id="RemoveLayerDll" Name="XR_APILAYER_cooooked_xrviewlab.dll" On="uninstall"/>
            <RemoveFile Id="RemoveLayerJson" Name="XR_APILAYER_cooooked_xrviewlab.json" On="uninstall"/>
            <RemoveFile Id="RemoveLogFile" Name="xr-viewlab.log" On="uninstall"/>
            <RemoveFile Id="RemoveOldLayerDll" Name="XR_APILAYER_cooooked_verticaltangent.dll" On="both"/>
            <RemoveFile Id="RemoveOldLayerJson" Name="XR_APILAYER_cooooked_verticaltangent.json" On="both"/>
            <RemoveFile Id="RemoveOldConfigFile" Name="openxr-verticaltangent.ini" On="both"/>
            <RemoveFile Id="RemoveOldLogFile" Name="openxr-verticaltangent.log" On="both"/>
            <RemoveFolder Id="RemoveInstallDirFromLayerFiles" On="uninstall"/>
          </Component>
          <Component Id="AppFiles" Guid="B5EC7B3F-8094-43B8-A6B4-9E4D48B8281A" Win64="yes">
            <File Id="SettingsApp" Source="..\bin\Release\net8.0-windows\win-x64\publish\xr-viewlab.exe" Name="xr-viewlab.exe" KeyPath="yes"/>
            <File Id="AppIconFile" Source="..\app.ico" Name="xr-viewlab.ico"/>
            <RemoveFile Id="RemoveSettingsApp" Name="xr-viewlab.exe" On="uninstall"/>
            <RemoveFile Id="RemoveAppIconFile" Name="xr-viewlab.ico" On="uninstall"/>
            <RemoveFile Id="RemoveOldSettingsApp" Name="openxr-verticaltangent.exe" On="both"/>
          </Component>
          <Component Id="RegEnable" Guid="7CFF3A28-702B-49EB-BD2C-CFD2B2A7FA77" Win64="yes">
            <RegistryValue Root="HKLM"
                           Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                           Name="[#LayerJson]"
                           Type="integer"
                           Value="0"
                           Action="write"
                           KeyPath="yes"/>
            <RemoveRegistryValue Root="HKLM"
                                 Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                                 Name="C:\Program Files\xr-viewlab\XR_APILAYER_cooooked_xrviewlab.json"/>
            <RemoveRegistryValue Root="HKLM"
                                 Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                                 Name="C:\Program Files\openxr-verticaltangent\XR_APILAYER_cooooked_verticaltangent.json"/>
            <RemoveRegistryValue Root="HKLM"
                                 Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                                 Name="C:\Program Files\openxr-verticaltangent-overlaytest\XR_APILAYER_cooooked_verticaltangent_overlaytest.json"/>
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="XR ViewLab">
          <Component Id="StartMenuShortcut" Guid="3AE9AB79-5298-4921-B099-9F98E8383356" Win64="yes">
            <Shortcut Id="StartMenuShortcut"
                      Name="XR ViewLab"
                      Description="Configure OpenXR VR render height and width"
                      Target="[#SettingsApp]"
                      Icon="ProductIcon"
                      WorkingDirectory="INSTALLFOLDER"/>
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
            <RegistryValue Root="HKCU" Key="Software\cooooked\xr-viewlab" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>
    </Directory>
    <Icon Id="ProductIcon" SourceFile="..\app.ico"/>
  </Product>
</Wix>
