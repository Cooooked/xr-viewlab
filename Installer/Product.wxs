<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension"
     xmlns:iis="http://schemas.microsoft.com/wix/IIsExtension">
  <Product Id="*" Name="ViewLab"
           Language="1033" Version="4.1.278"
           Manufacturer="cooooked"
           UpgradeCode="1FD1263B-D12E-46C8-9B07-D0F4C1E7AD87">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade DowngradeErrorMessage="A newer version is already installed."
                  AllowSameVersionUpgrades="yes"
                  IgnoreRemoveFailure="no"
                  MigrateFeatures="yes"
                  Schedule="afterInstallInitialize"
                  RemoveFeatures="all" />
    <Property Id="ARPCOMMENTS" Value="Tunes OpenXR VR render height and width" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon" />
    <Property Id="REBOOT" Value="ReallySuppress" />
    <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />
    <Property Id="MsiLogging" Value="voicewarmupx" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />

    <Binary Id="CreateDesktopShortcutVbs" SourceFile="CreateDesktopShortcut.vbs" />
    <Binary Id="NotificationIdentityCertificate" SourceFile="..\NotificationBroker\package-build\ViewLab.NotificationIdentity.cer" />
    <CustomAction Id="PromptDesktopShortcut"
                  BinaryKey="CreateDesktopShortcutVbs"
                  VBScriptCall="PromptDesktopShortcut"
                  Execute="immediate"
                  Return="ignore" />
    <CustomAction Id="PromptLaunchXRViewLab"
                  BinaryKey="CreateDesktopShortcutVbs"
                  VBScriptCall="PromptLaunchXRViewLab"
                  Execute="immediate"
                  Return="ignore" />
    <CustomAction Id="SetRemoveNotificationIdentityCommand"
                  Property="RemoveNotificationIdentity"
                  Value="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoLogo -NoProfile -NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -Command &quot;&amp; { Get-Process 'ViewLab.NotificationBroker' -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue; Get-AppxPackage -AllUsers -Name 'cooooked.ViewLab.NotificationBroker' | ForEach-Object { Remove-AppxPackage -Package $_.PackageFullName -AllUsers -ErrorAction SilentlyContinue } }&quot;"
                  Execute="immediate" />
    <CustomAction Id="RemoveNotificationIdentity"
                  BinaryKey="WixCA"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Return="ignore"
                  Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="SetRemoveNotificationIdentityCommand" Before="RemoveNotificationIdentity">REMOVE~=&quot;ALL&quot;</Custom>
      <Custom Action="RemoveNotificationIdentity" Before="RemoveFiles">REMOVE~=&quot;ALL&quot;</Custom>
    </InstallExecuteSequence>

    <UI>
      <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
      <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
      <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />
      <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
      <Property Id="WixUI_Mode" Value="InstallDir" />

      <DialogRef Id="BrowseDlg" />
      <DialogRef Id="DiskCostDlg" />
      <DialogRef Id="ErrorDlg" />
      <DialogRef Id="FatalError" />
      <DialogRef Id="FilesInUse" />
      <DialogRef Id="MsiRMFilesInUse" />
      <DialogRef Id="PrepareDlg" />
      <DialogRef Id="ProgressDlg" />
      <DialogRef Id="ResumeDlg" />
      <DialogRef Id="UserExit" />

      <Publish Dialog="BrowseDlg" Control="OK" Event="DoAction" Value="WixUIValidatePath" Order="3">1</Publish>
      <Publish Dialog="BrowseDlg" Control="OK" Event="SpawnDialog" Value="InvalidDirDlg" Order="4"><![CDATA[NOT WIXUI_DONTVALIDATEPATH AND WIXUI_INSTALLDIR_VALID<>"1"]]></Publish>
      <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999">1</Publish>
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg">NOT Installed</Publish>
      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg">Installed AND PATCH</Publish>
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="SetTargetPath" Value="[WIXUI_INSTALLDIR]" Order="1">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="DoAction" Value="WixUIValidatePath" Order="2">NOT WIXUI_DONTVALIDATEPATH</Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="SpawnDialog" Value="InvalidDirDlg" Order="3"><![CDATA[NOT WIXUI_DONTVALIDATEPATH AND WIXUI_INSTALLDIR_VALID<>"1"]]></Publish>
      <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Order="4">WIXUI_DONTVALIDATEPATH OR WIXUI_INSTALLDIR_VALID="1"</Publish>
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Property="_BrowseProperty" Value="[WIXUI_INSTALLDIR]" Order="1">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="ChangeFolder" Event="SpawnDialog" Value="BrowseDlg" Order="2">1</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="InstallDirDlg" Order="1">NOT Installed</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2">Installed AND NOT PATCH</Publish>
      <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2">Installed AND PATCH</Publish>
      <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg">1</Publish>
      <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
      <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="VerifyReadyDlg">1</Publish>
      <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg">1</Publish>

      <Property Id="ARPNOMODIFY" Value="1" />
      <UIRef Id="WixUI_Common" />
      <UIRef Id="WixUI_ErrorProgressText" />
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="PromptDesktopShortcut" Order="1">NOT Installed</Publish>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="PromptLaunchXRViewLab" Order="2">NOT Installed</Publish>
    </UI>

    <Feature Id="Main" Title="ViewLab" Level="1">
      <ComponentRef Id="LayerFiles"/>
      <ComponentRef Id="LayerFiles32"/>
      <ComponentRef Id="AppFiles"/>
      <ComponentRef Id="NotificationBrokerFiles"/>
      <ComponentRef Id="RegEnable"/>
      <ComponentRef Id="RegEnable32"/>
      <ComponentRef Id="StartMenuShortcut"/>
      <ComponentRef Id="ReShadePayloadFiles"/>
      <ComponentRef Id="ReShadePayloadDocs"/>
      <ComponentRef Id="ObsPluginFiles"/>
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="xr-viewlab">
          <Component Id="LayerFiles" Guid="A3E0E51C-45C2-45AA-B458-2F37F261C40A" Win64="yes">
            <File Id="LayerDll" Source="..\x64\Release\XR_APILAYER_cooooked_xrviewlab.dll" Name="XR_APILAYER_cooooked_xrviewlab.dll"/>
            <File Id="LayerJson" Source="..\XR_APILAYER_cooooked_xrviewlab.json" Name="XR_APILAYER_cooooked_xrviewlab.json"/>
            <RemoveFile Id="RemoveLayerDll" Name="XR_APILAYER_cooooked_xrviewlab.dll" On="uninstall"/>
            <RemoveFile Id="RemoveLayerJson" Name="XR_APILAYER_cooooked_xrviewlab.json" On="uninstall"/>
            <RemoveFile Id="RemoveLogFile" Name="xr-viewlab.log" On="uninstall"/>
            <RemoveFile Id="RemoveOldLayerDll" Name="XR_APILAYER_cooooked_verticaltangent.dll" On="both"/>
            <RemoveFile Id="RemoveOldLayerJson" Name="XR_APILAYER_cooooked_verticaltangent.json" On="both"/>
            <RemoveFolder Id="RemoveInstallDirFromLayerFiles" On="uninstall"/>
          </Component>
          <Component Id="AppFiles" Guid="B5EC7B3F-8094-43B8-A6B4-9E4D48B8281A" Win64="yes">
            <File Id="SettingsApp" Source="..\bin\Release\net8.0-windows10.0.19041.0\win-x64\publish\xr-viewlab.exe" Name="xr-viewlab.exe" KeyPath="yes"/>
            <File Id="AppIconFile" Source="..\app.ico" Name="xr-viewlab.ico"/>
            <File Id="DefaultConfigFile" Source="..\xr-viewlab.ini" Name="xr-viewlab.ini"/>
            <File Id="PresentMonConsole" Source="..\ThirdParty\PresentMon\PresentMon-2.4.1-x64.exe" Name="PresentMon-2.4.1-x64.exe"/>
            <File Id="PresentMonLicense" Source="..\ThirdParty\PresentMon\LICENSE.txt" Name="PresentMon-LICENSE.txt"/>
            <RemoveFile Id="RemoveSettingsApp" Name="xr-viewlab.exe" On="uninstall"/>
            <RemoveFile Id="RemoveDefaultConfigFile" Name="xr-viewlab.ini" On="uninstall"/>
            <RemoveFile Id="RemovePresentMonConsole" Name="PresentMon-2.4.1-x64.exe" On="uninstall"/>
            <RemoveFile Id="RemovePresentMonLicense" Name="PresentMon-LICENSE.txt" On="uninstall"/>
            <RemoveFile Id="RemoveReShadeMenuMirrorApp" Name="reshade-vr-menu.exe" On="both"/>
            <RemoveFile Id="RemoveReShadePackageZip" Name="reshade-package.zip" On="both"/>
            <RemoveFile Id="RemoveAppIconFile" Name="xr-viewlab.ico" On="uninstall"/>
          </Component>
          <Component Id="NotificationBrokerFiles" Guid="8E1F7C42-8E72-4E11-91C5-5988AB4AD119" Win64="yes">
            <File Id="NotificationBrokerExe" Source="..\NotificationBroker\bin\Release\net8.0-windows10.0.19041.0\win-x64\publish\ViewLab.NotificationBroker.exe" Name="ViewLab.NotificationBroker.exe" KeyPath="yes"/>
            <File Id="NotificationIdentityPackage" Source="..\NotificationBroker\package-build\ViewLab.NotificationIdentity.msix" Name="ViewLab.NotificationIdentity.msix"/>
            <File Id="NotificationIdentityPublicCertificate" Source="..\NotificationBroker\package-build\ViewLab.NotificationIdentity.cer" Name="ViewLab.NotificationIdentity.cer"/>
            <File Id="NotificationBrokerLogo" Source="..\NotificationBroker\package-build\xr-viewlab.png" Name="xr-viewlab.png"/>
            <RegistryValue Root="HKLM" Key="Software\Microsoft\Windows\CurrentVersion\Run" Name="ViewLab Notification Broker" Type="string" Value="&quot;[#NotificationBrokerExe]&quot; --start"/>
            <iis:Certificate Id="NotificationIdentityTrustedCertificate"
                             Name="ViewLab Notification Identity"
                             StoreLocation="localMachine"
                             StoreName="trustedPeople"
                             Request="no"
                             BinaryKey="NotificationIdentityCertificate" />
            <RemoveFile Id="RemoveNotificationBrokerExe" Name="ViewLab.NotificationBroker.exe" On="uninstall"/>
            <RemoveFile Id="RemoveNotificationIdentityPackage" Name="ViewLab.NotificationIdentity.msix" On="uninstall"/>
            <RemoveFile Id="RemoveNotificationIdentityPublicCertificate" Name="ViewLab.NotificationIdentity.cer" On="uninstall"/>
            <RemoveFile Id="RemoveNotificationBrokerLogo" Name="xr-viewlab.png" On="uninstall"/>
          </Component>
          <Directory Id="ObsPluginFolder" Name="ObsPlugin">
            <Component Id="ObsPluginFiles" Guid="4C7A9E10-6D2B-4B4E-8F3A-1E9C05B7D2A8" Win64="yes">
              <File Id="ViewLabMirrorPluginDll" Source="..\ViewLabMirrorPlugin\x64\Release\viewlab-mirror.dll" Name="viewlab-mirror.dll" KeyPath="yes"/>
              <File Id="ViewLabMirrorPluginLicense" Source="..\ViewLabMirrorPlugin\LICENSE" Name="LICENSE.txt"/>
              <File Id="ViewLabMirrorPluginReadme" Source="..\ViewLabMirrorPlugin\README.md" Name="README.md"/>
              <RemoveFile Id="RemoveViewLabMirrorPluginDll" Name="viewlab-mirror.dll" On="uninstall"/>
              <RemoveFile Id="RemoveViewLabMirrorPluginLicense" Name="LICENSE.txt" On="uninstall"/>
              <RemoveFile Id="RemoveViewLabMirrorPluginReadme" Name="README.md" On="uninstall"/>
              <RemoveFolder Id="RemoveObsPluginFolder" On="uninstall"/>
            </Component>
          </Directory>
          <Directory Id="ReShadePayloadFolder" Name="ReShadePayload">
            <Component Id="ReShadePayloadFiles" Guid="D73B2F3B-0F6A-4EB5-A9B6-78F0E51F37E5" Win64="yes">
              <File Id="ReShadePayloadDll" Source="..\ReShadePayload\ReShade64.dll" Name="ReShade64.dll" KeyPath="yes"/>
              <File Id="ReShadePayloadJson" Source="..\ReShadePayload\ReShade64_XR.json" Name="ReShade64_XR.json"/>
              <File Id="ReShadePayloadReadme" Source="..\ReShadePayload\README_ViewLab.txt" Name="README_ViewLab.txt"/>
              <RemoveFolder Id="RemoveReShadePayloadFolder" On="uninstall"/>
            </Component>
            <Directory Id="ReShadePayloadDocsFolder" Name="Docs">
              <Component Id="ReShadePayloadDocs" Guid="92FDE26A-D9D7-4454-95FF-BD2B04DD097A" Win64="yes">
                <File Id="ReShadePayloadDocsOverview" Source="..\ReShadePayload\Docs\ReshadeAIO_OVERVIEW.md" Name="ReshadeAIO_OVERVIEW.md" KeyPath="yes"/>
                <File Id="ReShadePayloadDocsMemory" Source="..\ReShadePayload\Docs\ReshadeAIO_MEMORY.md" Name="ReshadeAIO_MEMORY.md"/>
                <File Id="ReShadePayloadDocsStatus" Source="..\ReShadePayload\Docs\ReshadeAIO_STATUS.md" Name="ReshadeAIO_STATUS.md"/>
                <File Id="ReShadePayloadDocsOpenComposite" Source="..\ReShadePayload\Docs\OpenComposite_ReShade_fix.md" Name="OpenComposite_ReShade_fix.md"/>
                <File Id="ReShadePayloadDocsDeployReference" Source="..\ReShadePayload\Docs\Deploy-ReShade.reference.ps1" Name="Deploy-ReShade.reference.ps1"/>
                <File Id="ReShadePayloadDocsAddGameReference" Source="..\ReShadePayload\Docs\Add-Game.reference.ps1" Name="Add-Game.reference.ps1"/>
                <File Id="ReShadePayloadDocsSourceBuild" Source="..\ReShadePayload\Docs\SOURCE_BUILD.md" Name="SOURCE_BUILD.md"/>
                <RemoveFolder Id="RemoveReShadePayloadDocsFolder" On="uninstall"/>
              </Component>
            </Directory>
          </Directory>
          <Component Id="RegEnable" Guid="7CFF3A28-702B-49EB-BD2C-CFD2B2A7FA77" Win64="yes">
            <RegistryValue Root="HKLM"
                           Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                           Name="[#LayerJson]"
                           Type="integer"
                           Value="0"
                           Action="write"
                           KeyPath="yes"/>
          </Component>
          <Component Id="RegEnable32" Guid="9C2F1A77-4B3E-4D2A-8E1F-AB12CD34EF56" Win64="no">
            <RegistryValue Root="HKLM"
                           Key="Software\Khronos\OpenXR\1\ApiLayers\Implicit"
                           Name="[#Layer32Json]"
                           Type="integer"
                           Value="0"
                           Action="write"
                           KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER32" Name="xr-viewlab">
          <Component Id="LayerFiles32" Guid="5F8AE758-6D85-4A0C-9D1B-1849B7F1ED55" Win64="no">
            <File Id="Layer32Dll" Source="..\Release\XR_APILAYER_cooooked_xrviewlab32.dll" Name="XR_APILAYER_cooooked_xrviewlab32.dll"/>
            <File Id="Layer32Json" Source="..\XR_APILAYER_cooooked_xrviewlab32.json" Name="XR_APILAYER_cooooked_xrviewlab32.json"/>
            <RemoveFile Id="RemoveLayer32Dll" Name="XR_APILAYER_cooooked_xrviewlab32.dll" On="uninstall"/>
            <RemoveFile Id="RemoveLayer32Json" Name="XR_APILAYER_cooooked_xrviewlab32.json" On="uninstall"/>
            <RemoveFolder Id="RemoveInstallDir32FromLayerFiles" On="uninstall"/>
          </Component>
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="ViewLab">
          <Component Id="StartMenuShortcut" Guid="3AE9AB79-5298-4921-B099-9F98E8383356" Win64="yes">
            <Shortcut Id="StartMenuShortcut"
                      Name="ViewLab"
                      Description="Configure OpenXR VR render height and width"
                      Target="[#SettingsApp]"
                      Icon="ProductIcon"
                      WorkingDirectory="INSTALLFOLDER"/>
            <RemoveFolder Id="ApplicationProgramsFolder" On="uninstall"/>
            <RegistryValue Root="HKLM" Key="Software\cooooked\xr-viewlab" Name="StartMenuShortcutInstalled" Type="integer" Value="1" KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>
    </Directory>
    <Icon Id="ProductIcon" SourceFile="..\app.ico"/>
  </Product>
</Wix>
